{
  "version": 3,
  "overrides": {
    "faq/index.html": {
      "path": "faq"
    },
    "best-practices/index.html": {
      "path": "best-practices"
    },
    "feedback/index.html": {
      "path": "feedback"
    },
    "community/index.html": {
      "path": "community"
    },
    "news/index.html": {
      "path": "news"
    },
    "docs/index.html": {
      "path": "docs"
    },
    "search/index.html": {
      "path": "search"
    },
    "index.html": {
      "path": ""
    }
  },
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "content-type": "text/plain; charset=utf-8",
        "cache-control": "public, max-age=3600, s-maxage=3600"
      },
      "src": "/robots.txt"
    },
    {
      "headers": {
        "content-type": "application/rss+xml; charset=utf-8",
        "cache-control": "public, max-age=3600, s-maxage=3600"
      },
      "src": "/rss.xml"
    },
    {
      "headers": {
        "content-type": "application/xml; charset=utf-8",
        "cache-control": "public, max-age=3600, s-maxage=3600"
      },
      "src": "/sitemap.xml"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "(?<__isr_route>/__nuxt_content/(?:.*))",
      "dest": "/__fallback"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}
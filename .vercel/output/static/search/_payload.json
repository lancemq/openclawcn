[{"data":1,"prerenderedAt":2295},["ShallowReactive",2],{"search:docs":3,"search:news":1601,"search:best-practices":2011},[4,78,218,267,391,551,632,777,842,1004,1147,1291,1450],{"id":5,"title":6,"body":7,"category":69,"description":70,"extension":71,"meta":72,"navigation":73,"path":74,"seo":75,"stem":76,"__hash__":77},"docs/docs/architecture.md","内容结构说明",{"type":8,"value":9,"toc":62},"minimark",[10,13,17,21,34,37,48,51],[11,12,6],"h1",{"id":6},[14,15,16],"p",{},"这个站点的目标不是展示建设过程，而是把 OpenClaw 相关信息按更适合中文用户理解的方式组织起来。",[18,19,20],"h2",{"id":20},"内容优先",[22,23,24,28,31],"ul",{},[25,26,27],"li",{},"首页优先回答“OpenClaw 是什么”",[25,29,30],{},"文档优先回答“如何理解和开始使用”",[25,32,33],{},"新闻优先承接版本更新、使用提醒和解读",[18,35,36],{"id":36},"中文用户优先",[22,38,39,42,45],{},[25,40,41],{},"术语尽量用中文解释",[25,43,44],{},"安装与使用路径按中文用户习惯组织",[25,46,47],{},"社区、反馈和 GitHub 入口保持清晰可见",[18,49,50],{"id":50},"技术边界清晰",[22,52,53,56,59],{},[25,54,55],{},"首页、新闻和文档优先由内容驱动",[25,57,58],{},"搜索、反馈和订阅负责辅助用户找到内容",[25,60,61],{},"部署平台属于内部实现，不作为对外内容主题",{"title":63,"searchDepth":64,"depth":64,"links":65},"",2,[66,67,68],{"id":20,"depth":64,"text":20},{"id":36,"depth":64,"text":36},{"id":50,"depth":64,"text":50},"架构","说明中文站点如何围绕 OpenClaw 的产品介绍、使用文档、更新和社区入口组织内容。","md",{},true,"/docs/architecture",{"title":6,"description":70},"docs/architecture","7aC6pxgyrUSCWpr7JZs5WJ5qQ9Dw2qJCu9MWduYlahE",{"id":79,"title":80,"body":81,"category":211,"description":212,"extension":71,"meta":213,"navigation":73,"path":214,"seo":215,"stem":216,"__hash__":217},"docs/docs/channels-overview.md","渠道能力概览",{"type":8,"value":82,"toc":198},[83,85,88,91,94,97,108,111,114,125,128,133,136,140,143,147,150,153,168,171,174,177],[11,84,80],{"id":80},[14,86,87],{},"OpenClaw 官方文档把 Channels 单独作为一个大类，这本身就说明：多渠道能力不是附属功能，而是系统结构的核心部分。",[18,89,90],{"id":90},"为什么渠道能力重要",[14,92,93],{},"普通聊天产品通常只有一个主入口，而 OpenClaw 更强调把同一个助手体系接到不同入口上。",[14,95,96],{},"这带来的变化是：",[22,98,99,102,105],{},[25,100,101],{},"你不需要在每个平台重新建立一套助手",[25,103,104],{},"不同入口可以共享更一致的能力结构",[25,106,107],{},"后续扩展工具、模型和规则时，不必每次都从零开始",[18,109,110],{"id":110},"更适合怎么理解渠道",[14,112,113],{},"不要一开始就把 Channels 理解成“支持了多少个平台”，更好的理解方式是：",[22,115,116,119,122],{},[25,117,118],{},"它是消息入口层",[25,120,121],{},"它连接的是同一个助手系统",[25,123,124],{},"它的价值在于统一，而不只是数量",[18,126,127],{"id":127},"中文用户做选择时该看什么",[129,130,132],"h3",{"id":131},"_1-先看自己主要在哪里使用","1. 先看自己主要在哪里使用",[14,134,135],{},"如果你主要通过某类消息工具工作，就优先看那个渠道，不要同时展开多个入口。",[129,137,139],{"id":138},"_2-再看维护成本","2. 再看维护成本",[14,141,142],{},"多渠道不是越多越好。对第一次使用来说，先跑通一条渠道，通常比同时接三条更稳。",[129,144,146],{"id":145},"_3-最后看安全和边界","3. 最后看安全和边界",[14,148,149],{},"每多一个渠道，就多一层入口和风险面。所以渠道扩展应当放在已经理解基础结构之后再做。",[18,151,152],{"id":152},"推荐的第一次接入顺序",[154,155,156,159,162,165],"ol",{},[25,157,158],{},"一个管理入口",[25,160,161],{},"一个最常用的消息入口",[25,163,164],{},"跑通最小链路",[25,166,167],{},"再决定是否扩展第二个渠道",[18,169,170],{"id":170},"这篇的边界",[14,172,173],{},"这一页先解决“为什么渠道能力重要”。具体某个平台怎么接、怎么配，适合单独拆成专题文档，不适合都堆在一页里。",[18,175,176],{"id":176},"下一步推荐",[22,178,179,186,192],{},[25,180,181],{},[182,183,185],"a",{"href":184},"/Users/maqi/code/openclawcn/content/docs/core-capabilities.md","OpenClaw 核心能力总览",[25,187,188],{},[182,189,191],{"href":190},"/Users/maqi/code/openclawcn/content/docs/hooks-overview.md","Hooks 能做什么",[25,193,194],{},[182,195,197],{"href":196},"/Users/maqi/code/openclawcn/content/docs/safety-basics.md","安全配置基础",{"title":63,"searchDepth":64,"depth":64,"links":199},[200,201,202,208,209,210],{"id":90,"depth":64,"text":90},{"id":110,"depth":64,"text":110},{"id":127,"depth":64,"text":127,"children":203},[204,206,207],{"id":131,"depth":205,"text":132},3,{"id":138,"depth":205,"text":139},{"id":145,"depth":205,"text":146},{"id":152,"depth":64,"text":152},{"id":170,"depth":64,"text":170},{"id":176,"depth":64,"text":176},"功能","先从“为什么需要多渠道”理解 OpenClaw，而不是一开始就纠结每个平台的接入细节。",{},"/docs/channels-overview",{"title":80,"description":212},"docs/channels-overview","I9qltx6ETyI5yWN9THzGFCwo_aYL8GOdTPqWj-2yhU8",{"id":219,"title":220,"body":221,"category":260,"description":261,"extension":71,"meta":262,"navigation":73,"path":263,"seo":264,"stem":265,"__hash__":266},"docs/docs/community.md","社区支持",{"type":8,"value":222,"toc":256},[223,225,228,231,242,245],[11,224,220],{"id":220},[14,226,227],{},"OpenClawCN 不只是静态介绍页，还会逐步承担中文社区入口的作用。",[18,229,230],{"id":230},"当前入口",[22,232,233,236,239],{},[25,234,235],{},"GitHub 仓库",[25,237,238],{},"Issue / 问题反馈",[25,240,241],{},"后续贡献说明",[18,243,244],{"id":244},"后续会补充",[22,246,247,250,253],{},[25,248,249],{},"常见问题整理",[25,251,252],{},"贡献指南",[25,254,255],{},"中文社区沟通渠道",{"title":63,"searchDepth":64,"depth":64,"links":257},[258,259],{"id":230,"depth":64,"text":230},{"id":244,"depth":64,"text":244},"社区","汇总 GitHub、问题反馈、贡献方式和后续社区入口。",{},"/docs/community",{"title":220,"description":261},"docs/community","AISY-jwqalqwbAXF7IcaWZXmjGSWBBHhT60T6WJK7BY",{"id":268,"title":269,"body":270,"category":384,"description":385,"extension":71,"meta":386,"navigation":73,"path":387,"seo":388,"stem":389,"__hash__":390},"docs/docs/control-ui.md","Control UI 是什么",{"type":8,"value":271,"toc":373},[272,275,278,281,284,287,301,304,307,315,318,321,324,328,331,335,338,342,345,348,351,354,356],[11,273,269],{"id":274},"control-ui-是什么",[14,276,277],{},"OpenClaw 不只是靠消息入口工作。官方文档单独强调了 Control UI，这说明它在整个系统里承担的是“可见、可管、可检查”的角色。",[18,279,280],{"id":280},"可以把它理解成什么",[14,282,283],{},"如果说聊天渠道更像是日常使用入口，那么 Control UI 更像是系统管理入口。",[14,285,286],{},"它更适合做这些事情：",[22,288,289,292,295,298],{},[25,290,291],{},"看当前系统是否正常运行",[25,293,294],{},"检查初始化是否完成",[25,296,297],{},"观察能力是否已经接通",[25,299,300],{},"调整一些运行与管理相关配置",[18,302,303],{"id":303},"它和聊天入口的区别",[14,305,306],{},"很多新用户会把 Control UI 和聊天窗口混为一谈。更准确的理解应该是：",[22,308,309,312],{},[25,310,311],{},"聊天入口偏“使用”",[25,313,314],{},"Control UI 偏“管理与观察”",[14,316,317],{},"这也是为什么第一次部署和排错时，Control UI 往往更重要。",[18,319,320],{"id":320},"什么时候最该打开它",[14,322,323],{},"推荐在以下阶段优先查看：",[129,325,327],{"id":326},"_1-首次安装完成后","1. 首次安装完成后",[14,329,330],{},"确认最小链路是否正常。",[129,332,334],{"id":333},"_2-开始扩展新渠道时","2. 开始扩展新渠道时",[14,336,337],{},"查看系统结构是否已经完整接通，而不是只看单个渠道报不报错。",[129,339,341],{"id":340},"_3-进行排错时","3. 进行排错时",[14,343,344],{},"如果你只盯着一个外部消息入口，很容易把问题误判成渠道问题。Control UI 更适合帮助你理解问题到底出在哪一层。",[18,346,347],{"id":347},"中文用户最容易忽略的一点",[14,349,350],{},"很多人第一次接触 OpenClaw 时，只想尽快进入“聊天”。但从长期使用来看，Control UI 往往才是你真正理解系统结构的地方。",[14,352,353],{},"它不是锦上添花的面板，而是把 OpenClaw 从“单个聊天体验”升级成“可管理系统”的关键入口。",[18,355,176],{"id":176},[22,357,358,364,369],{},[25,359,360],{},[182,361,363],{"href":362},"/Users/maqi/code/openclawcn/content/docs/onboarding-guide.md","Onboarding 引导流程说明",[25,365,366],{},[182,367,80],{"href":368},"/Users/maqi/code/openclawcn/content/docs/channels-overview.md",[25,370,371],{},[182,372,197],{"href":196},{"title":63,"searchDepth":64,"depth":64,"links":374},[375,376,377,382,383],{"id":280,"depth":64,"text":280},{"id":303,"depth":64,"text":303},{"id":320,"depth":64,"text":320,"children":378},[379,380,381],{"id":326,"depth":205,"text":327},{"id":333,"depth":205,"text":334},{"id":340,"depth":205,"text":341},{"id":347,"depth":64,"text":347},{"id":176,"depth":64,"text":176},"入门","理解 OpenClaw 的控制界面在整个系统里的作用，以及它适合处理哪些任务。",{},"/docs/control-ui",{"title":269,"description":385},"docs/control-ui","QqKzTSzjJjBiU4DxbctIEpp3HyXzKzqyfWKTP2O2oxI",{"id":392,"title":185,"body":393,"category":544,"description":545,"extension":71,"meta":546,"navigation":73,"path":547,"seo":548,"stem":549,"__hash__":550},"docs/docs/core-capabilities.md",{"type":8,"value":394,"toc":534},[395,398,401,405,408,411,422,426,429,432,446,450,453,456,460,463,466,470,473,484,487,491,494,497,500,503,517,519],[11,396,185],{"id":397},"openclaw-核心能力总览",[14,399,400],{},"官方文档当前把 OpenClaw 的能力组织成若干块：开始使用、渠道、agents、tools、models、platforms、gateway 与运维、帮助与参考。对中文用户来说，这说明它不是单一功能，而是一整套围绕助手运行的结构。",[18,402,404],{"id":403},"_1-渠道接入","1. 渠道接入",[14,406,407],{},"OpenClaw 的一大特点是渠道能力。你不一定只通过一个网页和它交互，而可能通过不同消息入口与同一个助手体系连接。",[14,409,410],{},"这带来的意义是：",[22,412,413,416,419],{},[25,414,415],{},"入口不再单一",[25,417,418],{},"助手能力更贴近日常通信方式",[25,420,421],{},"同一套配置和逻辑可以服务多个使用场景",[18,423,425],{"id":424},"_2-控制界面","2. 控制界面",[14,427,428],{},"除了聊天渠道，OpenClaw 还提供 Control UI 这类更适合管理和观察系统状态的入口。",[14,430,431],{},"这类入口通常更适合：",[22,433,434,437,440,443],{},[25,435,436],{},"首次完成配置",[25,438,439],{},"查看系统是否正常运行",[25,441,442],{},"调整能力和运行参数",[25,444,445],{},"做排查和检查",[18,447,449],{"id":448},"_3-引导与配置","3. 引导与配置",[14,451,452],{},"OpenClaw 官方文档强调 onboarding 和 setup 路径，这说明它希望用户先经过一轮可理解的初始化，而不是一开始就手写全部配置。",[14,454,455],{},"这对第一次使用很重要，因为它降低了理解系统结构时的门槛。",[18,457,459],{"id":458},"_4-工具与扩展","4. 工具与扩展",[14,461,462],{},"OpenClaw 的价值还在于它不是只调用模型。它还包含工具、hooks、平台能力以及后续可扩展的结构。",[14,464,465],{},"从中文站点角度看，这一层是后续最值得持续扩写的内容，因为很多用户真正卡住的地方，往往都在“怎么接进去”和“怎么安全使用”。",[18,467,469],{"id":468},"_5-模型与运行边界","5. 模型与运行边界",[14,471,472],{},"模型并不是 OpenClaw 的全部，但它是运行体系的一部分。更准确地说，OpenClaw 关心的是：",[22,474,475,478,481],{},[25,476,477],{},"模型从哪里来",[25,479,480],{},"怎么和工具、渠道、配置结合",[25,482,483],{},"如何在自己的部署边界里运行",[14,485,486],{},"这也是它和单纯聊天网页最大的区别之一。",[18,488,490],{"id":489},"_6-运维与网关","6. 运维与网关",[14,492,493],{},"当你开始把它长期运行起来，就会进入 gateway、远程访问、安全和运维问题。",[14,495,496],{},"很多用户会在这一层意识到：OpenClaw 不只是一个“AI 功能集合”，而是一套需要被管理的长期系统。",[18,498,499],{"id":499},"建议的理解顺序",[14,501,502],{},"最推荐的顺序是：",[154,504,505,508,511,514],{},[25,506,507],{},"先理解定位",[25,509,510],{},"再理解渠道和 Control UI",[25,512,513],{},"再理解 onboarding、工具和 hooks",[25,515,516],{},"最后再进入平台、模型和运维",[18,518,176],{"id":176},[22,520,521,525,530],{},[25,522,523],{},[182,524,80],{"href":368},[25,526,527],{},[182,528,269],{"href":529},"/Users/maqi/code/openclawcn/content/docs/control-ui.md",[25,531,532],{},[182,533,191],{"href":190},{"title":63,"searchDepth":64,"depth":64,"links":535},[536,537,538,539,540,541,542,543],{"id":403,"depth":64,"text":404},{"id":424,"depth":64,"text":425},{"id":448,"depth":64,"text":449},{"id":458,"depth":64,"text":459},{"id":468,"depth":64,"text":469},{"id":489,"depth":64,"text":490},{"id":499,"depth":64,"text":499},{"id":176,"depth":64,"text":176},"产品","用一页理解 OpenClaw 当前最重要的能力结构，包括渠道、控制台、扩展和运行边界。",{},"/docs/core-capabilities",{"title":185,"description":545},"docs/core-capabilities","z-vj5qy6s5vXzOFkEROV1r-zfNvgp9fHMlecBDhTPww",{"id":552,"title":553,"body":554,"category":384,"description":626,"extension":71,"meta":627,"navigation":73,"path":628,"seo":629,"stem":630,"__hash__":631},"docs/docs/getting-started.md","快速入门",{"type":8,"value":555,"toc":621},[556,558,561,564,593,596,607,610],[11,557,553],{"id":553},[14,559,560],{},"如果你是第一次接触 OpenClaw，最重要的不是立刻记住所有配置项，而是先建立一个清晰的理解顺序。",[18,562,563],{"id":563},"推荐阅读顺序",[154,565,566,573,580,585,590],{},[25,567,568,569],{},"先看 ",[182,570,572],{"href":571},"/Users/maqi/code/openclawcn/content/docs/what-is-openclaw.md","OpenClaw 是什么",[25,574,575,576],{},"再看 ",[182,577,579],{"href":578},"/Users/maqi/code/openclawcn/content/docs/who-is-openclaw-for.md","OpenClaw 适合哪些用户",[25,581,582,583],{},"然后进入 ",[182,584,185],{"href":184},[25,586,587,588],{},"接着阅读 ",[182,589,363],{"href":362},[25,591,592],{},"最后再看渠道、Hooks 和安全基础",[18,594,595],{"id":595},"第一次使用时先回答三个问题",[22,597,598,601,604],{},[25,599,600],{},"我为什么需要 OpenClaw，而不是普通聊天工具？",[25,602,603],{},"我更关心哪类入口或渠道？",[25,605,606],{},"我是想先理解结构，还是已经准备开始接入？",[18,608,609],{"id":609},"接下来去哪里",[22,611,612,615,618],{},[25,613,614],{},"想先了解定位：看产品介绍",[25,616,617],{},"想先开始配置：看安装与 onboarding",[25,619,620],{},"想了解长期跟踪方式：看新闻、FAQ 和社区页",{"title":63,"searchDepth":64,"depth":64,"links":622},[623,624,625],{"id":563,"depth":64,"text":563},{"id":595,"depth":64,"text":595},{"id":609,"depth":64,"text":609},"用最短时间理解 OpenClaw 的定位、核心能力，以及第一次阅读时更推荐的中文路径。",{},"/docs/getting-started",{"title":553,"description":626},"docs/getting-started","5CJlIriqBYx-yqsFzbXD-VYww5Fua4uwjijzXvqaWCc",{"id":633,"title":191,"body":634,"category":211,"description":771,"extension":71,"meta":772,"navigation":73,"path":773,"seo":774,"stem":775,"__hash__":776},"docs/docs/hooks-overview.md",{"type":8,"value":635,"toc":760},[636,639,642,646,649,652,663,667,670,673,687,690,693,707,711,714,728,731,735,738,741,744,746],[11,637,191],{"id":638},"hooks-能做什么",[14,640,641],{},"从官方文档结构看，hooks 是 OpenClaw 里单独值得理解的一层。它的意义不只是“有一个技术能力”，而是给系统留出自动化扩展点。",[18,643,645],{"id":644},"可以把-hooks-理解成什么","可以把 hooks 理解成什么",[14,647,648],{},"更容易理解的说法是：hooks 是系统在某些关键阶段触发额外动作的机制。",[14,650,651],{},"它的价值在于：",[22,653,654,657,660],{},[25,655,656],{},"把固定流程自动化",[25,658,659],{},"把系统和外部逻辑接起来",[25,661,662],{},"减少人工重复操作",[18,664,666],{"id":665},"为什么这对-openclaw-很重要","为什么这对 OpenClaw 很重要",[14,668,669],{},"如果 OpenClaw 只是一个聊天窗口，hooks 的价值并不会这么明显。",[14,671,672],{},"但它是一个长期运行、可扩展、可接渠道的系统，所以 hooks 可以承担很多“系统级动作”：",[22,674,675,678,681,684],{},[25,676,677],{},"配置后的补充流程",[25,679,680],{},"某些事件发生后的自动响应",[25,682,683],{},"与外部服务的衔接",[25,685,686],{},"运维层面的触发动作",[18,688,689],{"id":689},"第一次使用时该怎么理解它",[14,691,692],{},"第一次接触 OpenClaw 时，不建议一开始就把 hooks 写得特别复杂。更稳的做法是：",[154,694,695,698,701,704],{},[25,696,697],{},"先理解它的角色",[25,699,700],{},"只保留最小自动化",[25,702,703],{},"跑通一条稳定链路",[25,705,706],{},"再逐步增加复杂动作",[18,708,710],{"id":709},"什么情况下值得引入-hooks","什么情况下值得引入 hooks",[14,712,713],{},"如果你已经出现这些需求，就说明 hooks 值得研究：",[22,715,716,719,722,725],{},[25,717,718],{},"某些步骤总是重复做",[25,720,721],{},"希望特定事件发生后自动执行动作",[25,723,724],{},"需要把 OpenClaw 和外部流程接起来",[25,726,727],{},"想减少人工检查与人工同步",[18,729,730],{"id":730},"中文用户常见误区",[129,732,734],{"id":733},"一上来就写很多-hooks","一上来就写很多 hooks",[14,736,737],{},"这样会让系统更难排错，也更难区分问题到底出在哪一层。",[129,739,740],{"id":740},"不理解触发边界",[14,742,743],{},"如果只知道“能挂逻辑”，但不知道“什么时候触发、影响哪一层”，后续维护成本会很高。",[18,745,563],{"id":563},[22,747,748,752,756],{},[25,749,750],{},[182,751,185],{"href":184},[25,753,754],{},[182,755,80],{"href":368},[25,757,758],{},[182,759,197],{"href":196},{"title":63,"searchDepth":64,"depth":64,"links":761},[762,763,764,765,766,770],{"id":644,"depth":64,"text":645},{"id":665,"depth":64,"text":666},{"id":689,"depth":64,"text":689},{"id":709,"depth":64,"text":710},{"id":730,"depth":64,"text":730,"children":767},[768,769],{"id":733,"depth":205,"text":734},{"id":740,"depth":205,"text":740},{"id":563,"depth":64,"text":563},"从中文用户角度理解 OpenClaw 里的 hooks，不把它只看成技术细节，而看成自动化扩展点。",{},"/docs/hooks-overview",{"title":191,"description":771},"docs/hooks-overview","O1TGonSUMH3OHcPXvRGNwQ65YHda5KCmSI4rv3ZxIks",{"id":778,"title":779,"body":780,"category":835,"description":836,"extension":71,"meta":837,"navigation":73,"path":838,"seo":839,"stem":840,"__hash__":841},"docs/docs/installation.md","安装与环境",{"type":8,"value":781,"toc":830},[782,784,787,790,804,806,817,819],[11,783,779],{"id":779},[14,785,786],{},"这一页不负责覆盖所有细节，而是先给中文用户一个清晰的准备顺序。",[18,788,789],{"id":789},"你需要先确认的内容",[22,791,792,795,798,801],{},[25,793,794],{},"当前使用的操作系统",[25,796,797],{},"Node.js 版本与包管理器",[25,799,800],{},"是否需要访问 OpenClaw 官方仓库与相关依赖源",[25,802,803],{},"本地是否具备运行示例和调试环境",[18,805,563],{"id":563},[154,807,808,811,814],{},[25,809,810],{},"先阅读快速入门，理解 OpenClaw 是什么",[25,812,813],{},"再整理本地运行环境",[25,815,816],{},"最后进入更具体的使用教程和最佳实践",[18,818,244],{"id":244},[22,820,821,824,827],{},[25,822,823],{},"Windows / macOS / Linux 的安装差异",[25,825,826],{},"常见报错与排查",[25,828,829],{},"针对中国网络环境的说明",{"title":63,"searchDepth":64,"depth":64,"links":831},[832,833,834],{"id":789,"depth":64,"text":789},{"id":563,"depth":64,"text":563},{"id":244,"depth":64,"text":244},"安装","面向中文用户整理 OpenClaw 的基础安装准备和环境认知。",{},"/docs/installation",{"title":779,"description":836},"docs/installation","4-8jg8RC5u6NbYUGJVpuqdI_RWu_bxdOTfyG73REgYE",{"id":843,"title":363,"body":844,"category":384,"description":998,"extension":71,"meta":999,"navigation":73,"path":1000,"seo":1001,"stem":1002,"__hash__":1003},"docs/docs/onboarding-guide.md",{"type":8,"value":845,"toc":984},[846,849,852,856,859,870,873,876,879,883,886,897,901,904,915,919,922,936,938,941,944,948,951,955,958,961],[11,847,363],{"id":848},"onboarding-引导流程说明",[14,850,851],{},"从官方文档结构看，OpenClaw 非常重视 onboarding。这个信息很关键，因为它意味着官方并不要求你第一次使用就理解全部内部结构，而是希望你先完成一轮受控的初始化。",[18,853,855],{"id":854},"为什么-onboarding-很重要","为什么 onboarding 很重要",[14,857,858],{},"对中文用户来说，第一次接触 OpenClaw 通常会遇到三个问题：",[22,860,861,864,867],{},[25,862,863],{},"不清楚先从哪里开始",[25,865,866],{},"不知道 Control UI、渠道和工具之间是什么关系",[25,868,869],{},"不确定哪些配置是现在就必须做的",[14,871,872],{},"onboarding 的价值，就是把这三个问题的顺序理清楚。",[18,874,875],{"id":875},"第一次配置最应该关注什么",[14,877,878],{},"建议把注意力放在下面几件事：",[129,880,882],{"id":881},"_1-先确认运行环境","1. 先确认运行环境",[14,884,885],{},"不要急着扩展渠道和高级能力，先确认：",[22,887,888,891,894],{},[25,889,890],{},"当前系统环境能正常跑起来",[25,892,893],{},"基础安装没有报错",[25,895,896],{},"最小链路已经能工作",[129,898,900],{"id":899},"_2-再确认入口","2. 再确认入口",[14,902,903],{},"第一次使用时，最重要的是知道自己准备通过什么入口和 OpenClaw 交互：",[22,905,906,909,912],{},[25,907,908],{},"是先通过 Control UI",[25,910,911],{},"还是先通过某个消息渠道",[25,913,914],{},"还是先从本地测试链路开始",[129,916,918],{"id":917},"_3-最后再扩展","3. 最后再扩展",[14,920,921],{},"完成第一轮 onboarding 后，再逐步进入：",[22,923,924,927,930,933],{},[25,925,926],{},"更多渠道",[25,928,929],{},"更多工具",[25,931,932],{},"hooks",[25,934,935],{},"安全与远程访问",[18,937,730],{"id":730},[129,939,940],{"id":940},"一开始就想把所有能力都接上",[14,942,943],{},"这会直接把第一次体验变成排错现场。更好的方法，是先跑通一条最小链路。",[129,945,947],{"id":946},"把-onboarding-当成一次性的步骤","把 onboarding 当成一次性的步骤",[14,949,950],{},"实际上，onboarding 更像“第一轮可控配置”，它不是终点，而是后续迭代的起点。",[129,952,954],{"id":953},"只关注界面不关注边界","只关注界面，不关注边界",[14,956,957],{},"OpenClaw 不是只有界面体验，入口、权限、模型、渠道和部署边界要一起看。",[18,959,960],{"id":960},"推荐的第一次使用顺序",[154,962,963,968,973,976,981],{},[25,964,965,966],{},"阅读 ",[182,967,572],{"href":571},[25,969,965,970],{},[182,971,779],{"href":972},"/Users/maqi/code/openclawcn/content/docs/installation.md",[25,974,975],{},"完成最小 onboarding",[25,977,978,979],{},"打开 ",[182,980,269],{"href":529},[25,982,983],{},"再决定是否扩展渠道和 hooks",{"title":63,"searchDepth":64,"depth":64,"links":985},[986,987,992,997],{"id":854,"depth":64,"text":855},{"id":875,"depth":64,"text":875,"children":988},[989,990,991],{"id":881,"depth":205,"text":882},{"id":899,"depth":205,"text":900},{"id":917,"depth":205,"text":918},{"id":730,"depth":64,"text":730,"children":993},[994,995,996],{"id":940,"depth":205,"text":940},{"id":946,"depth":205,"text":947},{"id":953,"depth":205,"text":954},{"id":960,"depth":64,"text":960},"为什么 OpenClaw 要强调 onboarding，以及中文用户第一次配置时应该关注什么。",{},"/docs/onboarding-guide",{"title":363,"description":998},"docs/onboarding-guide","m645noqiBiXgao9_8YSrppzCHN1kfbjsGphqf2SguHg",{"id":1005,"title":1006,"body":1007,"category":1140,"description":1141,"extension":71,"meta":1142,"navigation":73,"path":1143,"seo":1144,"stem":1145,"__hash__":1146},"docs/docs/release-tracking.md","如何持续跟踪 OpenClaw 更新",{"type":8,"value":1008,"toc":1129},[1009,1012,1015,1018,1021,1031,1034,1037,1040,1043,1046,1049,1060,1063,1066,1070,1078,1082,1088,1092,1095,1098,1109,1112,1115,1126],[11,1010,1006],{"id":1011},"如何持续跟踪-openclaw-更新",[14,1013,1014],{},"对于 OpenClaw 这种持续演进的系统，除了阅读基础文档，更重要的是建立“持续跟踪更新”的方法。否则内容很快就会过时。",[18,1016,1017],{"id":1017},"推荐关注的官方入口",[14,1019,1020],{},"最值得长期关注的有三类：",[22,1022,1023,1026,1028],{},[25,1024,1025],{},"官方文档",[25,1027,235],{},[25,1029,1030],{},"GitHub Releases",[14,1032,1033],{},"其中，Releases 最适合看版本变化，官方文档最适合看能力结构和使用方式，仓库则最适合补充真实讨论和实现方向。",[18,1035,1036],{"id":1036},"为什么不能只看一个入口",[14,1038,1039],{},"如果只看文档，你可能会错过版本变化节奏。",[14,1041,1042],{},"如果只看 release，你又可能不知道这些变化应该怎么被用户理解。",[14,1044,1045],{},"如果只看 issue，你会陷入局部问题，反而看不清主线。",[14,1047,1048],{},"更稳妥的方式，是把三类信息组合起来：",[154,1050,1051,1054,1057],{},[25,1052,1053],{},"先看 release 发生了什么",[25,1055,1056],{},"再看官方 docs 如何组织能力",[25,1058,1059],{},"最后看社区里哪些问题最常见",[18,1061,1062],{"id":1062},"中文站点怎么把更新转成内容",[14,1064,1065],{},"最推荐的做法是把更新分成三类：",[129,1067,1069],{"id":1068},"_1-版本速览","1. 版本速览",[14,1071,1072,1073,1077],{},"用于 ",[1074,1075,1076],"code",{},"/news","，快速回答“这次版本主要发生了什么”。",[129,1079,1081],{"id":1080},"_2-功能解读","2. 功能解读",[14,1083,1072,1084,1087],{},[1074,1085,1086],{},"/docs","，把某个功能做成长期可读的中文说明。",[129,1089,1091],{"id":1090},"_3-升级提醒","3. 升级提醒",[14,1093,1094],{},"用于最佳实践或 FAQ，回答“我需不需要马上改配置、有哪些风险”。",[18,1096,1097],{"id":1097},"建议的跟踪频率",[22,1099,1100,1103,1106],{},[25,1101,1102],{},"每周至少看一次 releases",[25,1104,1105],{},"每次重要版本后补一篇中文摘要",[25,1107,1108],{},"每次能力结构变化时补对应文档页",[18,1110,1111],{"id":1111},"当前最实用的做法",[14,1113,1114],{},"如果你还不想搭复杂自动化，先做下面三件事就够：",[154,1116,1117,1120,1123],{},[25,1118,1119],{},"订阅 RSS 或 GitHub Release 动态",[25,1121,1122],{},"每周看一次官方 docs 目录变化",[25,1124,1125],{},"把重要更新同步进中文新闻页",[14,1127,1128],{},"这样就能让站点内容保持基本的新鲜度。",{"title":63,"searchDepth":64,"depth":64,"links":1130},[1131,1132,1133,1138,1139],{"id":1017,"depth":64,"text":1017},{"id":1036,"depth":64,"text":1036},{"id":1062,"depth":64,"text":1062,"children":1134},[1135,1136,1137],{"id":1068,"depth":205,"text":1069},{"id":1080,"depth":205,"text":1081},{"id":1090,"depth":205,"text":1091},{"id":1097,"depth":64,"text":1097},{"id":1111,"depth":64,"text":1111},"更新","用最小成本持续关注 OpenClaw 的官方更新，而不是等有问题时才回头补信息。",{},"/docs/release-tracking",{"title":1006,"description":1141},"docs/release-tracking","szY-AATNahRy9dBdZ1oPyzBFuXbx5UrfTaBgoU33Cd8",{"id":1148,"title":197,"body":1149,"category":1284,"description":1285,"extension":71,"meta":1286,"navigation":73,"path":1287,"seo":1288,"stem":1289,"__hash__":1290},"docs/docs/safety-basics.md",{"type":8,"value":1150,"toc":1268},[1151,1153,1156,1159,1162,1176,1179,1182,1186,1189,1193,1196,1200,1203,1207,1210,1213,1217,1220,1223,1226,1229,1232,1235,1252,1254],[11,1152,197],{"id":197},[14,1154,1155],{},"对 OpenClaw 这种可运行、可接渠道、可扩展的系统来说，安全不是上线后再补的事情，而是第一轮配置就必须考虑的部分。",[18,1157,1158],{"id":1158},"为什么这里要先讲安全",[14,1160,1161],{},"因为一旦你开始做下面这些事情，风险面就会立刻扩大：",[22,1163,1164,1167,1170,1173],{},[25,1165,1166],{},"开远程访问",[25,1168,1169],{},"接外部消息渠道",[25,1171,1172],{},"暴露管理界面",[25,1174,1175],{},"给工具和插件更高权限",[14,1177,1178],{},"所以中文资料站应该尽早把“安全基础”放进核心内容，而不是藏在附录里。",[18,1180,1181],{"id":1181},"最基础的四个原则",[129,1183,1185],{"id":1184},"_1-先跑本地再谈公开入口","1. 先跑本地，再谈公开入口",[14,1187,1188],{},"第一次安装时，尽量先在本地验证最小链路，不要一开始就把入口暴露到公网。",[129,1190,1192],{"id":1191},"_2-管理入口和使用入口分开看","2. 管理入口和使用入口分开看",[14,1194,1195],{},"Control UI 这类管理入口的安全要求，通常应高于普通聊天入口。不要把它们当成同一类东西处理。",[129,1197,1199],{"id":1198},"_3-新增渠道就新增一层边界","3. 新增渠道就新增一层边界",[14,1201,1202],{},"每接一个渠道，都等于多一个入口、多一组凭证和多一层潜在错误配置。",[129,1204,1206],{"id":1205},"_4-先最小权限后逐步放开","4. 先最小权限，后逐步放开",[14,1208,1209],{},"无论是工具、hooks 还是远程能力，都应优先从最小范围开始，而不是一次性全部开放。",[18,1211,1212],{"id":1212},"中文用户最容易踩的坑",[129,1214,1216],{"id":1215},"只关注能不能跑不关注是不是暴露过头","只关注能不能跑，不关注是不是暴露过头",[14,1218,1219],{},"这会导致系统虽然“跑起来了”，但已经处在不合适的公开状态。",[129,1221,1222],{"id":1222},"在不了解边界前就接多个外部入口",[14,1224,1225],{},"这样一旦出错，排查复杂度会迅速升高。",[129,1227,1228],{"id":1228},"把安全理解成后期运维问题",[14,1230,1231],{},"实际上，它从第一次安装就开始了。",[18,1233,1234],{"id":1234},"第一次使用时的最低建议",[22,1236,1237,1240,1243,1246,1249],{},[25,1238,1239],{},"先本地验证",[25,1241,1242],{},"先一个入口",[25,1244,1245],{},"先最小权限",[25,1247,1248],{},"先明确谁能访问管理界面",[25,1250,1251],{},"再决定是否开放远程访问",[18,1253,176],{"id":176},[22,1255,1256,1260,1264],{},[25,1257,1258],{},[182,1259,269],{"href":529},[25,1261,1262],{},[182,1263,80],{"href":368},[25,1265,1266],{},[182,1267,191],{"href":190},{"title":63,"searchDepth":64,"depth":64,"links":1269},[1270,1271,1277,1282,1283],{"id":1158,"depth":64,"text":1158},{"id":1181,"depth":64,"text":1181,"children":1272},[1273,1274,1275,1276],{"id":1184,"depth":205,"text":1185},{"id":1191,"depth":205,"text":1192},{"id":1198,"depth":205,"text":1199},{"id":1205,"depth":205,"text":1206},{"id":1212,"depth":64,"text":1212,"children":1278},[1279,1280,1281],{"id":1215,"depth":205,"text":1216},{"id":1222,"depth":205,"text":1222},{"id":1228,"depth":205,"text":1228},{"id":1234,"depth":64,"text":1234},{"id":176,"depth":64,"text":176},"运维","在开始公开接入渠道、Control UI 或远程访问前，先理解 OpenClaw 最基础的安全边界。",{},"/docs/safety-basics",{"title":197,"description":1285},"docs/safety-basics","rCd4g0GM0gnJRAh_1BkRpdLbgioSdTzVBSlK6hpLZJM",{"id":1292,"title":572,"body":1293,"category":544,"description":1444,"extension":71,"meta":1445,"navigation":73,"path":1446,"seo":1447,"stem":1448,"__hash__":1449},"docs/docs/what-is-openclaw.md",{"type":8,"value":1294,"toc":1437},[1295,1298,1301,1304,1328,1331,1334,1345,1348,1351,1354,1357,1374,1377,1380,1391,1394,1397,1400,1414,1417,1420,1423],[11,1296,572],{"id":1297},"openclaw-是什么",[14,1299,1300],{},"OpenClaw 可以理解成一套“可自行托管、可扩展、可接入多渠道”的个人 AI 助手系统。它不是单独一个聊天窗口，而更像一个可以持续运行、持续接消息、持续调用工具的助手框架。",[14,1302,1303],{},"对中文用户来说，理解 OpenClaw 最重要的不是先记住所有功能，而是先抓住三个关键词：",[22,1305,1306,1314,1321],{},[25,1307,1308,1309,1313],{},"它是 ",[1310,1311,1312],"strong",{},"自己的助手系统","，不是某个平台托管给你的封闭产品",[25,1315,1316,1317,1320],{},"它强调 ",[1310,1318,1319],{},"渠道接入和扩展能力","，不只服务于一个网页聊天框",[25,1322,1323,1324,1327],{},"它更接近 ",[1310,1325,1326],{},"可运行的工作流与代理系统","，而不是只会回答问题的聊天机器人",[18,1329,1330],{"id":1330},"可以把它看成什么",[14,1332,1333],{},"更容易理解的方式，是把 OpenClaw 看成三层结构：",[154,1335,1336,1339,1342],{},[25,1337,1338],{},"最外层是你接触它的入口，比如不同聊天渠道、网页控制台和 API",[25,1340,1341],{},"中间层是路由、记忆、工具、插件和模型等运行能力",[25,1343,1344],{},"最底层是你自己的部署环境和配置边界",[14,1346,1347],{},"这意味着 OpenClaw 的价值，不只是“能聊”，而是“能接、能管、能扩展、能长期运行”。",[18,1349,1350],{"id":1350},"它解决什么问题",[14,1352,1353],{},"如果你只是偶尔问一个问题，普通聊天产品就够了。",[14,1355,1356],{},"但如果你需要的是下面这些事情，OpenClaw 才更有意义：",[22,1358,1359,1362,1365,1368,1371],{},[25,1360,1361],{},"把同一个助手接到多个入口",[25,1363,1364],{},"让助手具备更稳定的工具调用能力",[25,1366,1367],{},"把配置、权限和数据边界掌握在自己手里",[25,1369,1370],{},"让助手长期运行，而不是每次临时打开一个网页",[25,1372,1373],{},"围绕自己的工作流持续迭代能力",[18,1375,1376],{"id":1376},"它不是什么",[14,1378,1379],{},"为了避免误解，也要明确 OpenClaw 不是什么：",[22,1381,1382,1385,1388],{},[25,1383,1384],{},"它不是开箱即用、零配置的消费级聊天应用",[25,1386,1387],{},"它不是只靠一个模型就能自动解决所有问题的“万能 AI”",[25,1389,1390],{},"它不是只讲视觉界面体验的单页面产品",[14,1392,1393],{},"如果你希望的是“注册后立即完成所有事情”，OpenClaw 反而可能显得更偏工程化。",[18,1395,1396],{"id":1396},"对中文用户最重要的理解顺序",[14,1398,1399],{},"建议按这个顺序认识 OpenClaw：",[154,1401,1402,1405,1408,1411],{},[25,1403,1404],{},"先理解它的定位和边界",[25,1406,1407],{},"再理解它的入口和渠道能力",[25,1409,1410],{},"然后看安装、onboarding 和 Control UI",[25,1412,1413],{},"最后才深入插件、hooks、模型、网关和运维",[14,1415,1416],{},"这样读起来会比一开始就钻进配置项更轻松。",[18,1418,1419],{"id":1419},"下一步建议",[14,1421,1422],{},"如果你刚开始接触 OpenClaw，推荐继续看：",[22,1424,1425,1429,1433],{},[25,1426,1427],{},[182,1428,579],{"href":578},[25,1430,1431],{},[182,1432,185],{"href":184},[25,1434,1435],{},[182,1436,363],{"href":362},{"title":63,"searchDepth":64,"depth":64,"links":1438},[1439,1440,1441,1442,1443],{"id":1330,"depth":64,"text":1330},{"id":1350,"depth":64,"text":1350},{"id":1376,"depth":64,"text":1376},{"id":1396,"depth":64,"text":1396},{"id":1419,"depth":64,"text":1419},"用中文快速理解 OpenClaw 的定位、使用方式和它与普通聊天产品的差别。",{},"/docs/what-is-openclaw",{"title":572,"description":1444},"docs/what-is-openclaw","vFO_CJUabYxZZmHmaFIXw3UpAcN5Wek52BfK3X1BmAA",{"id":1451,"title":579,"body":1452,"category":544,"description":1595,"extension":71,"meta":1596,"navigation":73,"path":1597,"seo":1598,"stem":1599,"__hash__":1600},"docs/docs/who-is-openclaw-for.md",{"type":8,"value":1453,"toc":1581},[1454,1457,1460,1463,1467,1470,1473,1487,1491,1494,1497,1511,1515,1518,1521,1524,1528,1531,1535,1538,1542,1545,1548,1551,1562,1565,1567],[11,1455,579],{"id":1456},"openclaw-适合哪些用户",[14,1458,1459],{},"OpenClaw 并不是“所有人都该立即使用”的产品。它的价值主要出现在你已经对 AI 助手有持续使用需求，并且希望把入口、配置和扩展能力掌握在自己手里时。",[18,1461,1462],{"id":1462},"更适合的用户",[129,1464,1466],{"id":1465},"_1-个人效率重度用户","1. 个人效率重度用户",[14,1468,1469],{},"如果你已经把 AI 用在日常工作里，并且希望它不仅能聊天，还能跨多个入口长期为你服务，那么 OpenClaw 更值得研究。",[14,1471,1472],{},"这类用户通常会关心：",[22,1474,1475,1478,1481,1484],{},[25,1476,1477],{},"能否长期运行",[25,1479,1480],{},"能否多渠道接入",[25,1482,1483],{},"能否接工具或插件",[25,1485,1486],{},"能否保留自己的配置和边界",[129,1488,1490],{"id":1489},"_2-技术团队和独立开发者","2. 技术团队和独立开发者",[14,1492,1493],{},"如果你想围绕 AI 助手做实验、做工作流、做团队内部工具，OpenClaw 的工程化结构会比消费级产品更合适。",[14,1495,1496],{},"这类场景通常重视：",[22,1498,1499,1502,1505,1508],{},[25,1500,1501],{},"可自托管",[25,1503,1504],{},"可配置",[25,1506,1507],{},"可扩展",[25,1509,1510],{},"可与现有系统整合",[129,1512,1514],{"id":1513},"_3-对隐私和控制权更敏感的用户","3. 对隐私和控制权更敏感的用户",[14,1516,1517],{},"OpenClaw 的一个核心吸引力，是让你更清楚地知道自己的入口、模型、工具和部署边界分别在哪里。",[14,1519,1520],{},"如果你不希望所有能力都锁在第三方平台里，这一点会很重要。",[18,1522,1523],{"id":1523},"不那么适合的用户",[129,1525,1527],{"id":1526},"_1-只想立刻开箱即用的人","1. 只想立刻开箱即用的人",[14,1529,1530],{},"如果你的目标只是“马上找个聊天工具来问问题”，OpenClaw 的学习成本可能偏高。",[129,1532,1534],{"id":1533},"_2-不愿意接触配置和部署的人","2. 不愿意接触配置和部署的人",[14,1536,1537],{},"即使界面做得再友好，它本质上仍然是一套需要理解结构的系统。完全不想碰配置的人，通常会更适合纯托管产品。",[129,1539,1541],{"id":1540},"_3-只需要单一网页聊天体验的人","3. 只需要单一网页聊天体验的人",[14,1543,1544],{},"如果你根本不打算接入多渠道、插件或工具，那 OpenClaw 的优势就很难真正发挥出来。",[18,1546,1547],{"id":1547},"中文用户如何判断自己需不需要",[14,1549,1550],{},"可以用下面三个问题快速判断：",[154,1552,1553,1556,1559],{},[25,1554,1555],{},"我是不是希望 AI 助手长期运行，而不是每次临时打开网页？",[25,1557,1558],{},"我是不是希望它能接入多个渠道或工具？",[25,1560,1561],{},"我是不是希望配置和边界可控，而不是完全依赖平台？",[14,1563,1564],{},"如果三个问题里至少有两个答案是“是”，那 OpenClaw 值得继续了解。",[18,1566,563],{"id":563},[22,1568,1569,1573,1577],{},[25,1570,568,1571],{},[182,1572,572],{"href":571},[25,1574,575,1575],{},[182,1576,185],{"href":184},[25,1578,582,1579],{},[182,1580,779],{"href":972},{"title":63,"searchDepth":64,"depth":64,"links":1582},[1583,1588,1593,1594],{"id":1462,"depth":64,"text":1462,"children":1584},[1585,1586,1587],{"id":1465,"depth":205,"text":1466},{"id":1489,"depth":205,"text":1490},{"id":1513,"depth":205,"text":1514},{"id":1523,"depth":64,"text":1523,"children":1589},[1590,1591,1592],{"id":1526,"depth":205,"text":1527},{"id":1533,"depth":205,"text":1534},{"id":1540,"depth":205,"text":1541},{"id":1547,"depth":64,"text":1547},{"id":563,"depth":64,"text":563},"判断你是否真的需要 OpenClaw，以及它更适合哪类中文用户和团队。",{},"/docs/who-is-openclaw-for",{"title":579,"description":1595},"docs/who-is-openclaw-for","lCRPDPH8vohYWYgFQsEoTr79xsipmuIEtas0KIv9Uqw",[1602,1648,1704,1760,1814,1864,1910,1959],{"id":1603,"title":1604,"body":1605,"category":1640,"date":1641,"description":1642,"extension":71,"meta":1643,"navigation":73,"path":1644,"seo":1645,"stem":1646,"__hash__":1647},"news/news/best-practices-launch.md","OpenClaw 中文最佳实践专题",{"type":8,"value":1606,"toc":1636},[1607,1610,1613,1616,1630,1633],[11,1608,1604],{"id":1609},"openclaw-中文最佳实践专题",[14,1611,1612],{},"除了产品介绍和快速开始，OpenClaw 还需要一类更偏“方法”的内容。最佳实践专题解决的就是这个问题。",[18,1614,1615],{"id":1615},"当前专题重点",[22,1617,1618,1621,1624,1627],{},[25,1619,1620],{},"多渠道接入节奏",[25,1622,1623],{},"FAQ、反馈和 GitHub 协作路径",[25,1625,1626],{},"如何长期跟踪版本变化",[25,1628,1629],{},"第一次接触 OpenClaw 时更合适的阅读顺序",[18,1631,1632],{"id":1632},"为什么它有价值",[14,1634,1635],{},"它不是重复文档内容，而是把“怎么做更稳”整理成更适合长期阅读的经验页。",{"title":63,"searchDepth":64,"depth":64,"links":1637},[1638,1639],{"id":1615,"depth":64,"text":1615},{"id":1632,"depth":64,"text":1632},"专题导读","2026-03-09","围绕多渠道接入、协作反馈、更新跟踪和入门顺序整理稳定可读的专题内容。",{},"/news/best-practices-launch",{"title":1604,"description":1642},"news/best-practices-launch","hU1k5I39JtRGoM2dA1fx-enU-MbsaK_w43mIoACVAVk",{"id":1649,"title":1650,"body":1651,"category":1697,"date":1641,"description":1698,"extension":71,"meta":1699,"navigation":73,"path":1700,"seo":1701,"stem":1702,"__hash__":1703},"news/news/community-rss-launch.md","社区与 RSS 跟踪方式说明",{"type":8,"value":1652,"toc":1693},[1653,1656,1659,1662,1676,1679],[11,1654,1650],{"id":1655},"社区与-rss-跟踪方式说明",[14,1657,1658],{},"如果你希望长期跟踪 OpenClaw，最实用的不是一次性读完全部资料，而是建立自己的跟踪路径。",[18,1660,1661],{"id":1661},"推荐组合",[22,1663,1664,1667,1670,1673],{},[25,1665,1666],{},"FAQ 负责解决高频问题",[25,1668,1669],{},"反馈负责补齐中文资料缺口",[25,1671,1672],{},"GitHub 负责公开讨论与问题追踪",[25,1674,1675],{},"RSS 负责长期跟踪版本和内容变化",[18,1677,1678],{"id":1678},"更适合哪类用户",[22,1680,1681,1684,1687,1690],{},[25,1682,1683],{},"想长期关注变化的人适合 RSS",[25,1685,1686],{},"想快速解决问题的人先看 FAQ",[25,1688,1689],{},"想补充中文内容的人适合反馈",[25,1691,1692],{},"需要公开协作的人适合 GitHub",{"title":63,"searchDepth":64,"depth":64,"links":1694},[1695,1696],{"id":1661,"depth":64,"text":1661},{"id":1678,"depth":64,"text":1678},"社区观察","整理 GitHub、FAQ、反馈和 RSS 的使用方式，帮助长期关注 OpenClaw 更新。",{},"/news/community-rss-launch",{"title":1650,"description":1698},"news/community-rss-launch","j1GXHdnnfmiT8VRaRuvJ_EVksa3wUNvmifucrfvcM_U",{"id":1705,"title":1706,"body":1707,"category":1640,"date":1641,"description":1754,"extension":71,"meta":1755,"navigation":73,"path":1756,"seo":1757,"stem":1758,"__hash__":1759},"news/news/content-seeding-batch-1.md","首批中文专题内容导读",{"type":8,"value":1708,"toc":1750},[1709,1711,1714,1717,1736,1739],[11,1710,1706],{"id":1706},[14,1712,1713],{},"如果你第一次进入站点，不一定知道应该从哪些页面开始读。当前更推荐把阅读顺序收拢到几个核心专题。",[18,1715,1716],{"id":1716},"推荐优先阅读",[22,1718,1719,1721,1723,1726,1729,1731,1733],{},[25,1720,572],{},[25,1722,579],{},[25,1724,1725],{},"核心能力总览",[25,1727,1728],{},"Onboarding 与 Control UI",[25,1730,80],{},[25,1732,197],{},[25,1734,1735],{},"更新跟踪方式",[18,1737,1738],{"id":1738},"为什么这样更适合中文用户",[22,1740,1741,1744,1747],{},[25,1742,1743],{},"不会被大量零散页面打断",[25,1745,1746],{},"能先建立整体认知再深入",[25,1748,1749],{},"阅读完成后更容易知道下一步该去新闻、FAQ 还是社区",{"title":63,"searchDepth":64,"depth":64,"links":1751},[1752,1753],{"id":1716,"depth":64,"text":1716},{"id":1738,"depth":64,"text":1738},"汇总当前最适合中文用户连续阅读的产品介绍、入门文档和功能专题。",{},"/news/content-seeding-batch-1",{"title":1706,"description":1754},"news/content-seeding-batch-1","kC9IDg76Vraz0QVv6mtCEwK4RG3vT91jnp9GGtWYx-c",{"id":1761,"title":1762,"body":1763,"category":1806,"date":1807,"description":1808,"extension":71,"meta":1809,"navigation":73,"path":1810,"seo":1811,"stem":1812,"__hash__":1813},"news/news/content-structure.md","如何开始系统理解 OpenClaw",{"type":8,"value":1764,"toc":1802},[1765,1768,1771,1774,1788,1791],[11,1766,1762],{"id":1767},"如何开始系统理解-openclaw",[14,1769,1770],{},"第一次接触 OpenClaw 时，很容易因为文档类目较多而失去方向。更稳妥的方式，是先建立一个“从定位到配置”的阅读顺序。",[18,1772,1773],{"id":1773},"推荐顺序",[154,1775,1776,1779,1782,1785],{},[25,1777,1778],{},"先看产品定位和适用场景",[25,1780,1781],{},"再看核心能力总览",[25,1783,1784],{},"再进入安装、onboarding 和 Control UI",[25,1786,1787],{},"最后再看 channels、hooks、安全和更新跟踪",[18,1789,1790],{"id":1790},"为什么这样更适合第一次阅读",[22,1792,1793,1796,1799],{},[25,1794,1795],{},"能先搞清楚整体地图",[25,1797,1798],{},"不会一开始就被配置项淹没",[25,1800,1801],{},"读到后面时更容易知道哪些内容和自己有关",{"title":63,"searchDepth":64,"depth":64,"links":1803},[1804,1805],{"id":1773,"depth":64,"text":1773},{"id":1790,"depth":64,"text":1790},"使用指南","2026-03-06","给第一次接触 OpenClaw 的中文用户一条更清晰的阅读路径，避免一开始就陷入配置细节。",{},"/news/content-structure",{"title":1762,"description":1808},"news/content-structure","CHTl3oMAUoQIHHMQX0_6hficLTDboGAwOEeAyxHxwlU",{"id":1815,"title":1816,"body":1817,"category":1697,"date":1857,"description":1858,"extension":71,"meta":1859,"navigation":73,"path":1860,"seo":1861,"stem":1862,"__hash__":1863},"news/news/demo-ready-step2.md","FAQ 与订阅入口整理",{"type":8,"value":1818,"toc":1853},[1819,1822,1825,1828,1839,1842],[11,1820,1816],{"id":1821},"faq-与订阅入口整理",[14,1823,1824],{},"很多用户不是缺一个功能，而是缺一条长期跟踪信息的路径。FAQ 和订阅入口的价值，就在于降低“下次我去哪里看更新”的成本。",[18,1826,1827],{"id":1827},"更适合长期使用的方式",[22,1829,1830,1833,1836],{},[25,1831,1832],{},"常见问题先集中到 FAQ",[25,1834,1835],{},"版本和专题更新通过 RSS 或订阅入口跟踪",[25,1837,1838],{},"需要补充信息时再进入反馈与 GitHub",[18,1840,1841],{"id":1841},"对中文用户有什么帮助",[22,1843,1844,1847,1850],{},[25,1845,1846],{},"不需要反复手动检查有没有新内容",[25,1848,1849],{},"第一次提问前就能先看到高频问题",[25,1851,1852],{},"有利于把零散问题逐步沉淀成更稳定的资料",{"title":63,"searchDepth":64,"depth":64,"links":1854},[1855,1856],{"id":1827,"depth":64,"text":1827},{"id":1841,"depth":64,"text":1841},"2026-03-08","把常见问题、更新订阅和长期跟踪方式整理成更清晰的公开入口。",{},"/news/demo-ready-step2",{"title":1816,"description":1858},"news/demo-ready-step2","qxajyw3tCy-jsbiCjLTIefIfe1El4f_8vop_kaAQVeg",{"id":1865,"title":1866,"body":1867,"category":1902,"date":1903,"description":1904,"extension":71,"meta":1905,"navigation":73,"path":1906,"seo":1907,"stem":1908,"__hash__":1909},"news/news/mvp-launch.md","OpenClaw 2026.3.7 版本观察",{"type":8,"value":1868,"toc":1898},[1869,1872,1875,1878,1892,1895],[11,1870,1866],{"id":1871},"openclaw-202637-版本观察",[14,1873,1874],{},"从公开 release 节奏来看，OpenClaw 仍在持续快速演进。对中文用户来说，关注版本变化时最重要的不是记住所有细节，而是判断哪些变化会影响自己的理解和使用。",[18,1876,1877],{"id":1877},"更值得优先关注的方向",[22,1879,1880,1883,1886,1889],{},[25,1881,1882],{},"onboarding 与首次使用路径",[25,1884,1885],{},"routing / memory 这类会影响整体使用方式的能力",[25,1887,1888],{},"文档结构是否出现新的大类",[25,1890,1891],{},"对渠道、插件、工具和安全边界的说明有没有变化",[18,1893,1894],{"id":1894},"阅读建议",[14,1896,1897],{},"如果你时间有限，建议先看 release 摘要，再回到官方 docs 对照能力结构，而不是一开始就追所有实现细节。",{"title":63,"searchDepth":64,"depth":64,"links":1899},[1900,1901],{"id":1877,"depth":64,"text":1877},{"id":1894,"depth":64,"text":1894},"产品更新","2026-03-05","结合最新 release 观察当前版本中最值得中文用户优先关注的变化方向。",{},"/news/mvp-launch",{"title":1866,"description":1904},"news/mvp-launch","irjIdMOeBYwFS1J3b-xf0Gs5iNs89Or00jRTavz14G8",{"id":1911,"title":1912,"body":1
[{"data":1,"prerenderedAt":2286},["ShallowReactive",2],{"search:docs":3,"search:news":1627,"search:best-practices":2085},[4,81,221,270,394,554,654,800,865,1028,1168,1312,1473],{"id":5,"title":6,"body":7,"category":72,"description":73,"extension":74,"meta":75,"navigation":76,"path":77,"seo":78,"stem":79,"__hash__":80},"docs/docs/architecture.md","架构约束",{"type":8,"value":9,"toc":65},"minimark",[10,13,17,21,34,37,48,51],[11,12,6],"h1",{"id":6},[14,15,16],"p",{},"为了让项目从一开始就清晰可维护，本项目默认遵循以下约束：",[18,19,20],"h2",{"id":20},"内容优先",[22,23,24,28,31],"ul",{},[25,26,27],"li",{},"首页优先回答“OpenClaw 是什么”",[25,29,30],{},"文档优先回答“如何理解和开始使用”",[25,32,33],{},"新闻优先承接项目更新与社区动态",[18,35,36],{"id":36},"中文用户优先",[22,38,39,42,45],{},[25,40,41],{},"术语尽量用中文解释",[25,43,44],{},"安装与使用路径按中文用户习惯组织",[25,46,47],{},"社区、反馈和 GitHub 入口保持清晰可见",[18,49,50],{"id":50},"技术边界清晰",[22,52,53,56,59,62],{},[25,54,55],{},"首页、新闻和文档优先由内容驱动",[25,57,58],{},"第 1 步不急于接入复杂后台",[25,60,61],{},"第 2 步再扩展搜索、反馈和动态接口",[25,63,64],{},"部署平台属于内部实现，不作为对外内容主题",{"title":66,"searchDepth":67,"depth":67,"links":68},"",2,[69,70,71],{"id":20,"depth":67,"text":20},{"id":36,"depth":67,"text":36},{"id":50,"depth":67,"text":50},"架构","第 1 步不是功能堆砌，而是先把中文官网的内容结构和技术边界定下来。","md",{},true,"/docs/architecture",{"title":6,"description":73},"docs/architecture","Nu3fTEMfUFJR4nN41kyUR1vmzD8ABACHIuZy6A_i7ko",{"id":82,"title":83,"body":84,"category":214,"description":215,"extension":74,"meta":216,"navigation":76,"path":217,"seo":218,"stem":219,"__hash__":220},"docs/docs/channels-overview.md","渠道能力概览",{"type":8,"value":85,"toc":201},[86,88,91,94,97,100,111,114,117,128,131,136,139,143,146,150,153,156,171,174,177,180],[11,87,83],{"id":83},[14,89,90],{},"OpenClaw 官方文档把 Channels 单独作为一个大类，这本身就说明：多渠道能力不是附属功能，而是系统结构的核心部分。",[18,92,93],{"id":93},"为什么渠道能力重要",[14,95,96],{},"普通聊天产品通常只有一个主入口，而 OpenClaw 更强调把同一个助手体系接到不同入口上。",[14,98,99],{},"这带来的变化是：",[22,101,102,105,108],{},[25,103,104],{},"你不需要在每个平台重新建立一套助手",[25,106,107],{},"不同入口可以共享更一致的能力结构",[25,109,110],{},"后续扩展工具、模型和规则时，不必每次都从零开始",[18,112,113],{"id":113},"更适合怎么理解渠道",[14,115,116],{},"不要一开始就把 Channels 理解成“支持了多少个平台”，更好的理解方式是：",[22,118,119,122,125],{},[25,120,121],{},"它是消息入口层",[25,123,124],{},"它连接的是同一个助手系统",[25,126,127],{},"它的价值在于统一，而不只是数量",[18,129,130],{"id":130},"中文用户做选择时该看什么",[132,133,135],"h3",{"id":134},"_1-先看自己主要在哪里使用","1. 先看自己主要在哪里使用",[14,137,138],{},"如果你主要通过某类消息工具工作，就优先看那个渠道，不要同时展开多个入口。",[132,140,142],{"id":141},"_2-再看维护成本","2. 再看维护成本",[14,144,145],{},"多渠道不是越多越好。对冷启动阶段来说，先跑通一条渠道，通常比同时接三条更稳。",[132,147,149],{"id":148},"_3-最后看安全和边界","3. 最后看安全和边界",[14,151,152],{},"每多一个渠道，就多一层入口和风险面。所以渠道扩展应当放在已经理解基础结构之后再做。",[18,154,155],{"id":155},"推荐的冷启动顺序",[157,158,159,162,165,168],"ol",{},[25,160,161],{},"一个管理入口",[25,163,164],{},"一个最常用的消息入口",[25,166,167],{},"跑通最小链路",[25,169,170],{},"再决定是否扩展第二个渠道",[18,172,173],{"id":173},"这篇的边界",[14,175,176],{},"这一页先解决“为什么渠道能力重要”。具体某个平台怎么接、怎么配，适合单独拆成专题文档，不适合都堆在一页里。",[18,178,179],{"id":179},"下一步推荐",[22,181,182,189,195],{},[25,183,184],{},[185,186,188],"a",{"href":187},"/Users/maqi/code/openclawcn/content/docs/core-capabilities.md","OpenClaw 核心能力总览",[25,190,191],{},[185,192,194],{"href":193},"/Users/maqi/code/openclawcn/content/docs/hooks-overview.md","Hooks 能做什么",[25,196,197],{},[185,198,200],{"href":199},"/Users/maqi/code/openclawcn/content/docs/safety-basics.md","安全配置基础",{"title":66,"searchDepth":67,"depth":67,"links":202},[203,204,205,211,212,213],{"id":93,"depth":67,"text":93},{"id":113,"depth":67,"text":113},{"id":130,"depth":67,"text":130,"children":206},[207,209,210],{"id":134,"depth":208,"text":135},3,{"id":141,"depth":208,"text":142},{"id":148,"depth":208,"text":149},{"id":155,"depth":67,"text":155},{"id":173,"depth":67,"text":173},{"id":179,"depth":67,"text":179},"功能","先从“为什么需要多渠道”理解 OpenClaw，而不是一开始就纠结每个平台的接入细节。",{},"/docs/channels-overview",{"title":83,"description":215},"docs/channels-overview","Dox5vweBGiKsGM91EiZthuAnYLZ5QxZNBNzaack9N6U",{"id":222,"title":223,"body":224,"category":263,"description":264,"extension":74,"meta":265,"navigation":76,"path":266,"seo":267,"stem":268,"__hash__":269},"docs/docs/community.md","社区支持",{"type":8,"value":225,"toc":259},[226,228,231,234,245,248],[11,227,223],{"id":223},[14,229,230],{},"OpenClawCN 不只是静态介绍页，还会逐步承担中文社区入口的作用。",[18,232,233],{"id":233},"当前入口",[22,235,236,239,242],{},[25,237,238],{},"GitHub 仓库",[25,240,241],{},"Issue / 问题反馈",[25,243,244],{},"后续贡献说明",[18,246,247],{"id":247},"后续会补充",[22,249,250,253,256],{},[25,251,252],{},"常见问题整理",[25,254,255],{},"贡献指南",[25,257,258],{},"中文社区沟通渠道",{"title":66,"searchDepth":67,"depth":67,"links":260},[261,262],{"id":233,"depth":67,"text":233},{"id":247,"depth":67,"text":247},"社区","汇总 GitHub、问题反馈、贡献方式和后续社区入口。",{},"/docs/community",{"title":223,"description":264},"docs/community","AISY-jwqalqwbAXF7IcaWZXmjGSWBBHhT60T6WJK7BY",{"id":271,"title":272,"body":273,"category":387,"description":388,"extension":74,"meta":389,"navigation":76,"path":390,"seo":391,"stem":392,"__hash__":393},"docs/docs/control-ui.md","Control UI 是什么",{"type":8,"value":274,"toc":376},[275,278,281,284,287,290,304,307,310,318,321,324,327,331,334,338,341,345,348,351,354,357,359],[11,276,272],{"id":277},"control-ui-是什么",[14,279,280],{},"OpenClaw 不只是靠消息入口工作。官方文档单独强调了 Control UI，这说明它在整个系统里承担的是“可见、可管、可检查”的角色。",[18,282,283],{"id":283},"可以把它理解成什么",[14,285,286],{},"如果说聊天渠道更像是日常使用入口，那么 Control UI 更像是系统管理入口。",[14,288,289],{},"它更适合做这些事情：",[22,291,292,295,298,301],{},[25,293,294],{},"看当前系统是否正常运行",[25,296,297],{},"检查初始化是否完成",[25,299,300],{},"观察能力是否已经接通",[25,302,303],{},"调整一些运行与管理相关配置",[18,305,306],{"id":306},"它和聊天入口的区别",[14,308,309],{},"很多新用户会把 Control UI 和聊天窗口混为一谈。更准确的理解应该是：",[22,311,312,315],{},[25,313,314],{},"聊天入口偏“使用”",[25,316,317],{},"Control UI 偏“管理与观察”",[14,319,320],{},"这也是为什么第一次部署和排错时，Control UI 往往更重要。",[18,322,323],{"id":323},"什么时候最该打开它",[14,325,326],{},"推荐在以下阶段优先查看：",[132,328,330],{"id":329},"_1-首次安装完成后","1. 首次安装完成后",[14,332,333],{},"确认最小链路是否正常。",[132,335,337],{"id":336},"_2-开始扩展新渠道时","2. 开始扩展新渠道时",[14,339,340],{},"查看系统结构是否已经完整接通，而不是只看单个渠道报不报错。",[132,342,344],{"id":343},"_3-进行排错时","3. 进行排错时",[14,346,347],{},"如果你只盯着一个外部消息入口，很容易把问题误判成渠道问题。Control UI 更适合帮助你理解问题到底出在哪一层。",[18,349,350],{"id":350},"中文用户最容易忽略的一点",[14,352,353],{},"很多人第一次接触 OpenClaw 时，只想尽快进入“聊天”。但从长期使用来看，Control UI 往往才是你真正理解系统结构的地方。",[14,355,356],{},"它不是锦上添花的面板，而是把 OpenClaw 从“单个聊天体验”升级成“可管理系统”的关键入口。",[18,358,179],{"id":179},[22,360,361,367,372],{},[25,362,363],{},[185,364,366],{"href":365},"/Users/maqi/code/openclawcn/content/docs/onboarding-guide.md","Onboarding 引导流程说明",[25,368,369],{},[185,370,83],{"href":371},"/Users/maqi/code/openclawcn/content/docs/channels-overview.md",[25,373,374],{},[185,375,200],{"href":199},{"title":66,"searchDepth":67,"depth":67,"links":377},[378,379,380,385,386],{"id":283,"depth":67,"text":283},{"id":306,"depth":67,"text":306},{"id":323,"depth":67,"text":323,"children":381},[382,383,384],{"id":329,"depth":208,"text":330},{"id":336,"depth":208,"text":337},{"id":343,"depth":208,"text":344},{"id":350,"depth":67,"text":350},{"id":179,"depth":67,"text":179},"入门","理解 OpenClaw 的控制界面在整个系统里的作用，以及它适合处理哪些任务。",{},"/docs/control-ui",{"title":272,"description":388},"docs/control-ui","QqKzTSzjJjBiU4DxbctIEpp3HyXzKzqyfWKTP2O2oxI",{"id":395,"title":188,"body":396,"category":547,"description":548,"extension":74,"meta":549,"navigation":76,"path":550,"seo":551,"stem":552,"__hash__":553},"docs/docs/core-capabilities.md",{"type":8,"value":397,"toc":537},[398,401,404,408,411,414,425,429,432,435,449,453,456,459,463,466,469,473,476,487,490,494,497,500,503,506,520,522],[11,399,188],{"id":400},"openclaw-核心能力总览",[14,402,403],{},"官方文档当前把 OpenClaw 的能力组织成若干块：开始使用、渠道、agents、tools、models、platforms、gateway 与运维、帮助与参考。对中文用户来说，这说明它不是单一功能，而是一整套围绕助手运行的结构。",[18,405,407],{"id":406},"_1-渠道接入","1. 渠道接入",[14,409,410],{},"OpenClaw 的一大特点是渠道能力。你不一定只通过一个网页和它交互，而可能通过不同消息入口与同一个助手体系连接。",[14,412,413],{},"这带来的意义是：",[22,415,416,419,422],{},[25,417,418],{},"入口不再单一",[25,420,421],{},"助手能力更贴近日常通信方式",[25,423,424],{},"同一套配置和逻辑可以服务多个使用场景",[18,426,428],{"id":427},"_2-控制界面","2. 控制界面",[14,430,431],{},"除了聊天渠道，OpenClaw 还提供 Control UI 这类更适合管理和观察系统状态的入口。",[14,433,434],{},"这类入口通常更适合：",[22,436,437,440,443,446],{},[25,438,439],{},"首次完成配置",[25,441,442],{},"查看系统是否正常运行",[25,444,445],{},"调整能力和运行参数",[25,447,448],{},"做排查和检查",[18,450,452],{"id":451},"_3-引导与配置","3. 引导与配置",[14,454,455],{},"OpenClaw 官方文档强调 onboarding 和 setup 路径，这说明它希望用户先经过一轮可理解的初始化，而不是一开始就手写全部配置。",[14,457,458],{},"这对冷启动很重要，因为它降低了第一次使用时的理解成本。",[18,460,462],{"id":461},"_4-工具与扩展","4. 工具与扩展",[14,464,465],{},"OpenClaw 的价值还在于它不是只调用模型。它还包含工具、hooks、平台能力以及后续可扩展的结构。",[14,467,468],{},"从中文站点角度看，这一层是后续最值得持续扩写的内容，因为很多用户真正卡住的地方，往往都在“怎么接进去”和“怎么安全使用”。",[18,470,472],{"id":471},"_5-模型与运行边界","5. 模型与运行边界",[14,474,475],{},"模型并不是 OpenClaw 的全部，但它是运行体系的一部分。更准确地说，OpenClaw 关心的是：",[22,477,478,481,484],{},[25,479,480],{},"模型从哪里来",[25,482,483],{},"怎么和工具、渠道、配置结合",[25,485,486],{},"如何在自己的部署边界里运行",[14,488,489],{},"这也是它和单纯聊天网页最大的区别之一。",[18,491,493],{"id":492},"_6-运维与网关","6. 运维与网关",[14,495,496],{},"当你开始把它长期运行起来，就会进入 gateway、远程访问、安全和运维问题。",[14,498,499],{},"很多用户会在这一层意识到：OpenClaw 不只是一个“AI 功能集合”，而是一套需要被管理的长期系统。",[18,501,502],{"id":502},"建议的理解顺序",[14,504,505],{},"最推荐的顺序是：",[157,507,508,511,514,517],{},[25,509,510],{},"先理解定位",[25,512,513],{},"再理解渠道和 Control UI",[25,515,516],{},"再理解 onboarding、工具和 hooks",[25,518,519],{},"最后再进入平台、模型和运维",[18,521,179],{"id":179},[22,523,524,528,533],{},[25,525,526],{},[185,527,83],{"href":371},[25,529,530],{},[185,531,272],{"href":532},"/Users/maqi/code/openclawcn/content/docs/control-ui.md",[25,534,535],{},[185,536,194],{"href":193},{"title":66,"searchDepth":67,"depth":67,"links":538},[539,540,541,542,543,544,545,546],{"id":406,"depth":67,"text":407},{"id":427,"depth":67,"text":428},{"id":451,"depth":67,"text":452},{"id":461,"depth":67,"text":462},{"id":471,"depth":67,"text":472},{"id":492,"depth":67,"text":493},{"id":502,"depth":67,"text":502},{"id":179,"depth":67,"text":179},"产品","用一页理解 OpenClaw 当前最重要的能力结构，包括渠道、控制台、扩展和运行边界。",{},"/docs/core-capabilities",{"title":188,"description":548},"docs/core-capabilities","FM4_PB6GOMfqWPy5L5tZtwb3pOq94AiZalY-duOnqQg",{"id":555,"title":556,"body":557,"category":387,"description":648,"extension":74,"meta":649,"navigation":76,"path":650,"seo":651,"stem":652,"__hash__":653},"docs/docs/getting-started.md","快速入门",{"type":8,"value":558,"toc":644},[559,561,564,578,581,613,616,640],[11,560,556],{"id":556},[14,562,563],{},"OpenClawCN 当前完成的是第 1 步 MVP，目标是先帮助中文用户理解 OpenClaw：",[22,565,566,569,572,575],{},[25,567,568],{},"首页可以说明 OpenClawCN 的定位",[25,570,571],{},"文档中心已经建立目录入口",[25,573,574],{},"新闻列表可以承接项目动态",[25,576,577],{},"社区与 GitHub 入口已经放到站点导航中",[18,579,580],{"id":580},"本地启动",[582,583,587],"pre",{"className":584,"code":585,"language":586,"meta":66,"style":66},"language-bash shiki shiki-themes github-light github-dark","npm install\nnpm run dev\n","bash",[588,589,590,603],"code",{"__ignoreMap":66},[591,592,595,599],"span",{"class":593,"line":594},"line",1,[591,596,598],{"class":597},"sScJk","npm",[591,600,602],{"class":601},"sZZnC"," install\n",[591,604,605,607,610],{"class":593,"line":67},[591,606,598],{"class":597},[591,608,609],{"class":601}," run",[591,611,612],{"class":601}," dev\n",[18,614,615],{"id":615},"当前可验证内容",[157,617,618,621,628,634],{},[25,619,620],{},"打开首页，确认 Hero、功能卡片和主要入口可见",[25,622,623,624,627],{},"打开 ",[588,625,626],{},"/docs","，确认文档目录可访问",[25,629,623,630,633],{},[588,631,632],{},"/news","，确认新闻列表可访问",[25,635,623,636,639],{},[588,637,638],{},"/api/health","，确认基础函数可返回 JSON",[641,642,643],"style",{},"html pre.shiki code .sScJk, html code.shiki .sScJk{--shiki-default:#6F42C1;--shiki-dark:#B392F0}html pre.shiki code .sZZnC, html code.shiki .sZZnC{--shiki-default:#032F62;--shiki-dark:#9ECBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":66,"searchDepth":67,"depth":67,"links":645},[646,647],{"id":580,"depth":67,"text":580},{"id":615,"depth":67,"text":615},"用最短时间了解 OpenClaw 是什么、适合谁，以及 OpenClawCN 当前提供了哪些中文入口。",{},"/docs/getting-started",{"title":556,"description":648},"docs/getting-started","nQB9yFR4cwGtGb0ZjT0zXDIhTfYDKoKqEUyklla8q94",{"id":655,"title":194,"body":656,"category":214,"description":794,"extension":74,"meta":795,"navigation":76,"path":796,"seo":797,"stem":798,"__hash__":799},"docs/docs/hooks-overview.md",{"type":8,"value":657,"toc":783},[658,661,664,668,671,674,685,689,692,695,709,712,715,729,733,736,750,753,757,760,763,766,769],[11,659,194],{"id":660},"hooks-能做什么",[14,662,663],{},"从官方文档结构看，hooks 是 OpenClaw 里单独值得理解的一层。它的意义不只是“有一个技术能力”，而是给系统留出自动化扩展点。",[18,665,667],{"id":666},"可以把-hooks-理解成什么","可以把 hooks 理解成什么",[14,669,670],{},"更容易理解的说法是：hooks 是系统在某些关键阶段触发额外动作的机制。",[14,672,673],{},"它的价值在于：",[22,675,676,679,682],{},[25,677,678],{},"把固定流程自动化",[25,680,681],{},"把系统和外部逻辑接起来",[25,683,684],{},"减少人工重复操作",[18,686,688],{"id":687},"为什么这对-openclaw-很重要","为什么这对 OpenClaw 很重要",[14,690,691],{},"如果 OpenClaw 只是一个聊天窗口，hooks 的价值并不会这么明显。",[14,693,694],{},"但它是一个长期运行、可扩展、可接渠道的系统，所以 hooks 可以承担很多“系统级动作”：",[22,696,697,700,703,706],{},[25,698,699],{},"配置后的补充流程",[25,701,702],{},"某些事件发生后的自动响应",[25,704,705],{},"与外部服务的衔接",[25,707,708],{},"运维层面的触发动作",[18,710,711],{"id":711},"冷启动阶段该怎么用它",[14,713,714],{},"在内容站冷启动阶段，不建议一开始就把 hooks 写得特别复杂。更稳的做法是：",[157,716,717,720,723,726],{},[25,718,719],{},"先理解它的角色",[25,721,722],{},"只保留最小自动化",[25,724,725],{},"跑通一条稳定链路",[25,727,728],{},"再逐步增加复杂动作",[18,730,732],{"id":731},"什么情况下值得引入-hooks","什么情况下值得引入 hooks",[14,734,735],{},"如果你已经出现这些需求，就说明 hooks 值得研究：",[22,737,738,741,744,747],{},[25,739,740],{},"某些步骤总是重复做",[25,742,743],{},"希望特定事件发生后自动执行动作",[25,745,746],{},"需要把 OpenClaw 和外部流程接起来",[25,748,749],{},"想减少人工检查与人工同步",[18,751,752],{"id":752},"中文用户常见误区",[132,754,756],{"id":755},"一上来就写很多-hooks","一上来就写很多 hooks",[14,758,759],{},"这样会让系统更难排错，也更难区分问题到底出在哪一层。",[132,761,762],{"id":762},"不理解触发边界",[14,764,765],{},"如果只知道“能挂逻辑”，但不知道“什么时候触发、影响哪一层”，后续维护成本会很高。",[18,767,768],{"id":768},"推荐阅读顺序",[22,770,771,775,779],{},[25,772,773],{},[185,774,188],{"href":187},[25,776,777],{},[185,778,83],{"href":371},[25,780,781],{},[185,782,200],{"href":199},{"title":66,"searchDepth":67,"depth":67,"links":784},[785,786,787,788,789,793],{"id":666,"depth":67,"text":667},{"id":687,"depth":67,"text":688},{"id":711,"depth":67,"text":711},{"id":731,"depth":67,"text":732},{"id":752,"depth":67,"text":752,"children":790},[791,792],{"id":755,"depth":208,"text":756},{"id":762,"depth":208,"text":762},{"id":768,"depth":67,"text":768},"从中文用户角度理解 OpenClaw 里的 hooks，不把它只看成技术细节，而看成自动化扩展点。",{},"/docs/hooks-overview",{"title":194,"description":794},"docs/hooks-overview","LLFN_OZqz0qqSpWeESk0Bkyb0wYzztVgfHpcMdOYqWc",{"id":801,"title":802,"body":803,"category":858,"description":859,"extension":74,"meta":860,"navigation":76,"path":861,"seo":862,"stem":863,"__hash__":864},"docs/docs/installation.md","安装与环境",{"type":8,"value":804,"toc":853},[805,807,810,813,827,829,840,842],[11,806,802],{"id":802},[14,808,809],{},"这一页不负责覆盖所有细节，而是先给中文用户一个清晰的准备顺序。",[18,811,812],{"id":812},"你需要先确认的内容",[22,814,815,818,821,824],{},[25,816,817],{},"当前使用的操作系统",[25,819,820],{},"Node.js 版本与包管理器",[25,822,823],{},"是否需要访问 OpenClaw 官方仓库与相关依赖源",[25,825,826],{},"本地是否具备运行示例和调试环境",[18,828,768],{"id":768},[157,830,831,834,837],{},[25,832,833],{},"先阅读快速入门，理解 OpenClaw 是什么",[25,835,836],{},"再整理本地运行环境",[25,838,839],{},"最后进入更具体的使用教程和最佳实践",[18,841,247],{"id":247},[22,843,844,847,850],{},[25,845,846],{},"Windows / macOS / Linux 的安装差异",[25,848,849],{},"常见报错与排查",[25,851,852],{},"针对中国网络环境的说明",{"title":66,"searchDepth":67,"depth":67,"links":854},[855,856,857],{"id":812,"depth":67,"text":812},{"id":768,"depth":67,"text":768},{"id":247,"depth":67,"text":247},"安装","面向中文用户整理 OpenClaw 的基础安装准备和环境认知。",{},"/docs/installation",{"title":802,"description":859},"docs/installation","4-8jg8RC5u6NbYUGJVpuqdI_RWu_bxdOTfyG73REgYE",{"id":866,"title":366,"body":867,"category":387,"description":1022,"extension":74,"meta":1023,"navigation":76,"path":1024,"seo":1025,"stem":1026,"__hash__":1027},"docs/docs/onboarding-guide.md",{"type":8,"value":868,"toc":1008},[869,872,875,879,882,893,896,899,902,906,909,920,924,927,938,942,945,959,961,964,967,971,974,978,981,984],[11,870,366],{"id":871},"onboarding-引导流程说明",[14,873,874],{},"从官方文档结构看，OpenClaw 非常重视 onboarding。这个信息很关键，因为它意味着官方并不要求你第一次使用就理解全部内部结构，而是希望你先完成一轮受控的初始化。",[18,876,878],{"id":877},"为什么-onboarding-很重要","为什么 onboarding 很重要",[14,880,881],{},"对中文用户来说，第一次接触 OpenClaw 通常会遇到三个问题：",[22,883,884,887,890],{},[25,885,886],{},"不清楚先从哪里开始",[25,888,889],{},"不知道 Control UI、渠道和工具之间是什么关系",[25,891,892],{},"不确定哪些配置是现在就必须做的",[14,894,895],{},"onboarding 的价值，就是把这三个问题的顺序理清楚。",[18,897,898],{"id":898},"第一次配置最应该关注什么",[14,900,901],{},"建议把注意力放在下面几件事：",[132,903,905],{"id":904},"_1-先确认运行环境","1. 先确认运行环境",[14,907,908],{},"不要急着扩展渠道和高级能力，先确认：",[22,910,911,914,917],{},[25,912,913],{},"当前系统环境能正常跑起来",[25,915,916],{},"基础安装没有报错",[25,918,919],{},"最小链路已经能工作",[132,921,923],{"id":922},"_2-再确认入口","2. 再确认入口",[14,925,926],{},"第一次使用时，最重要的是知道自己准备通过什么入口和 OpenClaw 交互：",[22,928,929,932,935],{},[25,930,931],{},"是先通过 Control UI",[25,933,934],{},"还是先通过某个消息渠道",[25,936,937],{},"还是先从本地测试链路开始",[132,939,941],{"id":940},"_3-最后再扩展","3. 最后再扩展",[14,943,944],{},"完成第一轮 onboarding 后，再逐步进入：",[22,946,947,950,953,956],{},[25,948,949],{},"更多渠道",[25,951,952],{},"更多工具",[25,954,955],{},"hooks",[25,957,958],{},"安全与远程访问",[18,960,752],{"id":752},[132,962,963],{"id":963},"一开始就想把所有能力都接上",[14,965,966],{},"这会直接把第一次体验变成排错现场。更好的方法，是先跑通一条最小链路。",[132,968,970],{"id":969},"把-onboarding-当成一次性的步骤","把 onboarding 当成一次性的步骤",[14,972,973],{},"实际上，onboarding 更像“第一轮可控配置”，它不是终点，而是后续迭代的起点。",[132,975,977],{"id":976},"只关注界面不关注边界","只关注界面，不关注边界",[14,979,980],{},"OpenClaw 不是只有界面体验，入口、权限、模型、渠道和部署边界要一起看。",[18,982,983],{"id":983},"推荐的第一次使用顺序",[157,985,986,993,998,1001,1005],{},[25,987,988,989],{},"阅读 ",[185,990,992],{"href":991},"/Users/maqi/code/openclawcn/content/docs/what-is-openclaw.md","OpenClaw 是什么",[25,994,988,995],{},[185,996,802],{"href":997},"/Users/maqi/code/openclawcn/content/docs/installation.md",[25,999,1000],{},"完成最小 onboarding",[25,1002,623,1003],{},[185,1004,272],{"href":532},[25,1006,1007],{},"再决定是否扩展渠道和 hooks",{"title":66,"searchDepth":67,"depth":67,"links":1009},[1010,1011,1016,1021],{"id":877,"depth":67,"text":878},{"id":898,"depth":67,"text":898,"children":1012},[1013,1014,1015],{"id":904,"depth":208,"text":905},{"id":922,"depth":208,"text":923},{"id":940,"depth":208,"text":941},{"id":752,"depth":67,"text":752,"children":1017},[1018,1019,1020],{"id":963,"depth":208,"text":963},{"id":969,"depth":208,"text":970},{"id":976,"depth":208,"text":977},{"id":983,"depth":67,"text":983},"为什么 OpenClaw 要强调 onboarding，以及中文用户第一次配置时应该关注什么。",{},"/docs/onboarding-guide",{"title":366,"description":1022},"docs/onboarding-guide","m645noqiBiXgao9_8YSrppzCHN1kfbjsGphqf2SguHg",{"id":1029,"title":1030,"body":1031,"category":1161,"description":1162,"extension":74,"meta":1163,"navigation":76,"path":1164,"seo":1165,"stem":1166,"__hash__":1167},"docs/docs/release-tracking.md","如何持续跟踪 OpenClaw 更新",{"type":8,"value":1032,"toc":1150},[1033,1036,1039,1042,1045,1055,1058,1061,1064,1067,1070,1073,1084,1087,1090,1094,1100,1104,1109,1113,1116,1119,1130,1133,1136,1147],[11,1034,1030],{"id":1035},"如何持续跟踪-openclaw-更新",[14,1037,1038],{},"对于 OpenClaw 这种持续演进的系统，冷启动阶段除了补基础内容，更重要的是建立“持续跟踪更新”的方法。否则内容很快就会过时。",[18,1040,1041],{"id":1041},"推荐关注的官方入口",[14,1043,1044],{},"最值得长期关注的有三类：",[22,1046,1047,1050,1052],{},[25,1048,1049],{},"官方文档",[25,1051,238],{},[25,1053,1054],{},"GitHub Releases",[14,1056,1057],{},"其中，Releases 最适合看版本变化，官方文档最适合看能力结构和使用方式，仓库则最适合补充真实讨论和实现方向。",[18,1059,1060],{"id":1060},"为什么不能只看一个入口",[14,1062,1063],{},"如果只看文档，你可能会错过版本变化节奏。",[14,1065,1066],{},"如果只看 release，你又可能不知道这些变化应该怎么被用户理解。",[14,1068,1069],{},"如果只看 issue，你会陷入局部问题，反而看不清主线。",[14,1071,1072],{},"更稳妥的方式，是把三类信息组合起来：",[157,1074,1075,1078,1081],{},[25,1076,1077],{},"先看 release 发生了什么",[25,1079,1080],{},"再看官方 docs 如何组织能力",[25,1082,1083],{},"最后看社区里哪些问题最常见",[18,1085,1086],{"id":1086},"中文站点怎么把更新转成内容",[14,1088,1089],{},"最推荐的做法是把更新分成三类：",[132,1091,1093],{"id":1092},"_1-版本速览","1. 版本速览",[14,1095,1096,1097,1099],{},"用于 ",[588,1098,632],{},"，快速回答“这次版本主要发生了什么”。",[132,1101,1103],{"id":1102},"_2-功能解读","2. 功能解读",[14,1105,1096,1106,1108],{},[588,1107,626],{},"，把某个功能做成长期可读的中文说明。",[132,1110,1112],{"id":1111},"_3-升级提醒","3. 升级提醒",[14,1114,1115],{},"用于最佳实践或 FAQ，回答“我需不需要马上改配置、有哪些风险”。",[18,1117,1118],{"id":1118},"建议的跟踪频率",[22,1120,1121,1124,1127],{},[25,1122,1123],{},"每周至少看一次 releases",[25,1125,1126],{},"每次重要版本后补一篇中文摘要",[25,1128,1129],{},"每次能力结构变化时补对应文档页",[18,1131,1132],{"id":1132},"当前最实用的做法",[14,1134,1135],{},"如果你还不想搭复杂自动化，先做下面三件事就够：",[157,1137,1138,1141,1144],{},[25,1139,1140],{},"订阅 RSS 或 GitHub Release 动态",[25,1142,1143],{},"每周看一次官方 docs 目录变化",[25,1145,1146],{},"把重要更新同步进中文新闻页",[14,1148,1149],{},"这样就能让站点内容保持基本的新鲜度。",{"title":66,"searchDepth":67,"depth":67,"links":1151},[1152,1153,1154,1159,1160],{"id":1041,"depth":67,"text":1041},{"id":1060,"depth":67,"text":1060},{"id":1086,"depth":67,"text":1086,"children":1155},[1156,1157,1158],{"id":1092,"depth":208,"text":1093},{"id":1102,"depth":208,"text":1103},{"id":1111,"depth":208,"text":1112},{"id":1118,"depth":67,"text":1118},{"id":1132,"depth":67,"text":1132},"更新","用最小成本持续关注 OpenClaw 的官方更新，而不是等有问题时才回头补信息。",{},"/docs/release-tracking",{"title":1030,"description":1162},"docs/release-tracking","PL7ZpJgBUVLVwuyy62AzMphY16PUdqxdYFYAV8Z2-Dk",{"id":1169,"title":200,"body":1170,"category":1305,"description":1306,"extension":74,"meta":1307,"navigation":76,"path":1308,"seo":1309,"stem":1310,"__hash__":1311},"docs/docs/safety-basics.md",{"type":8,"value":1171,"toc":1289},[1172,1174,1177,1180,1183,1197,1200,1203,1207,1210,1214,1217,1221,1224,1228,1231,1234,1238,1241,1244,1247,1250,1253,1256,1273,1275],[11,1173,200],{"id":200},[14,1175,1176],{},"对 OpenClaw 这种可运行、可接渠道、可扩展的系统来说，安全不是上线后再补的事情，而是第一轮配置就必须考虑的部分。",[18,1178,1179],{"id":1179},"为什么这里要先讲安全",[14,1181,1182],{},"因为一旦你开始做下面这些事情，风险面就会立刻扩大：",[22,1184,1185,1188,1191,1194],{},[25,1186,1187],{},"开远程访问",[25,1189,1190],{},"接外部消息渠道",[25,1192,1193],{},"暴露管理界面",[25,1195,1196],{},"给工具和插件更高权限",[14,1198,1199],{},"所以，中文站点在冷启动阶段就应该把“安全基础”放进核心内容，而不是藏在附录里。",[18,1201,1202],{"id":1202},"最基础的四个原则",[132,1204,1206],{"id":1205},"_1-先跑本地再谈公开入口","1. 先跑本地，再谈公开入口",[14,1208,1209],{},"第一次安装时，尽量先在本地验证最小链路，不要一开始就把入口暴露到公网。",[132,1211,1213],{"id":1212},"_2-管理入口和使用入口分开看","2. 管理入口和使用入口分开看",[14,1215,1216],{},"Control UI 这类管理入口的安全要求，通常应高于普通聊天入口。不要把它们当成同一类东西处理。",[132,1218,1220],{"id":1219},"_3-新增渠道就新增一层边界","3. 新增渠道就新增一层边界",[14,1222,1223],{},"每接一个渠道，都等于多一个入口、多一组凭证和多一层潜在错误配置。",[132,1225,1227],{"id":1226},"_4-先最小权限后逐步放开","4. 先最小权限，后逐步放开",[14,1229,1230],{},"无论是工具、hooks 还是远程能力，都应优先从最小范围开始，而不是一次性全部开放。",[18,1232,1233],{"id":1233},"中文用户最容易踩的坑",[132,1235,1237],{"id":1236},"只关注能不能跑不关注是不是暴露过头","只关注能不能跑，不关注是不是暴露过头",[14,1239,1240],{},"这会导致系统虽然“跑起来了”，但已经处在不合适的公开状态。",[132,1242,1243],{"id":1243},"在不了解边界前就接多个外部入口",[14,1245,1246],{},"这样一旦出错，排查复杂度会迅速升高。",[132,1248,1249],{"id":1249},"把安全理解成后期运维问题",[14,1251,1252],{},"实际上，它从第一次安装就开始了。",[18,1254,1255],{"id":1255},"冷启动阶段的最低建议",[22,1257,1258,1261,1264,1267,1270],{},[25,1259,1260],{},"先本地验证",[25,1262,1263],{},"先一个入口",[25,1265,1266],{},"先最小权限",[25,1268,1269],{},"先明确谁能访问管理界面",[25,1271,1272],{},"再决定是否开放远程访问",[18,1274,179],{"id":179},[22,1276,1277,1281,1285],{},[25,1278,1279],{},[185,1280,272],{"href":532},[25,1282,1283],{},[185,1284,83],{"href":371},[25,1286,1287],{},[185,1288,194],{"href":193},{"title":66,"searchDepth":67,"depth":67,"links":1290},[1291,1292,1298,1303,1304],{"id":1179,"depth":67,"text":1179},{"id":1202,"depth":67,"text":1202,"children":1293},[1294,1295,1296,1297],{"id":1205,"depth":208,"text":1206},{"id":1212,"depth":208,"text":1213},{"id":1219,"depth":208,"text":1220},{"id":1226,"depth":208,"text":1227},{"id":1233,"depth":67,"text":1233,"children":1299},[1300,1301,1302],{"id":1236,"depth":208,"text":1237},{"id":1243,"depth":208,"text":1243},{"id":1249,"depth":208,"text":1249},{"id":1255,"depth":67,"text":1255},{"id":179,"depth":67,"text":179},"运维","在开始公开接入渠道、Control UI 或远程访问前，先理解 OpenClaw 最基础的安全边界。",{},"/docs/safety-basics",{"title":200,"description":1306},"docs/safety-basics","CWtZAm9BucrxA4ACCXE9GKOhw2FRo8H5FDKIzGDvkVc",{"id":1313,"title":992,"body":1314,"category":547,"description":1467,"extension":74,"meta":1468,"navigation":76,"path":1469,"seo":1470,"stem":1471,"__hash__":1472},"docs/docs/what-is-openclaw.md",{"type":8,"value":1315,"toc":1460},[1316,1319,1322,1325,1349,1352,1355,1366,1369,1372,1375,1378,1395,1398,1401,1412,1415,1418,1421,1435,1438,1441,1444],[11,1317,992],{"id":1318},"openclaw-是什么",[14,1320,1321],{},"OpenClaw 可以理解成一套“可自行托管、可扩展、可接入多渠道”的个人 AI 助手系统。它不是单独一个聊天窗口，而更像一个可以持续运行、持续接消息、持续调用工具的助手框架。",[14,1323,1324],{},"对中文用户来说，理解 OpenClaw 最重要的不是先记住所有功能，而是先抓住三个关键词：",[22,1326,1327,1335,1342],{},[25,1328,1329,1330,1334],{},"它是 ",[1331,1332,1333],"strong",{},"自己的助手系统","，不是某个平台托管给你的封闭产品",[25,1336,1337,1338,1341],{},"它强调 ",[1331,1339,1340],{},"渠道接入和扩展能力","，不只服务于一个网页聊天框",[25,1343,1344,1345,1348],{},"它更接近 ",[1331,1346,1347],{},"可运行的工作流与代理系统","，而不是只会回答问题的聊天机器人",[18,1350,1351],{"id":1351},"可以把它看成什么",[14,1353,1354],{},"更容易理解的方式，是把 OpenClaw 看成三层结构：",[157,1356,1357,1360,1363],{},[25,1358,1359],{},"最外层是你接触它的入口，比如不同聊天渠道、网页控制台和 API",[25,1361,1362],{},"中间层是路由、记忆、工具、插件和模型等运行能力",[25,1364,1365],{},"最底层是你自己的部署环境和配置边界",[14,1367,1368],{},"这意味着 OpenClaw 的价值，不只是“能聊”，而是“能接、能管、能扩展、能长期运行”。",[18,1370,1371],{"id":1371},"它解决什么问题",[14,1373,1374],{},"如果你只是偶尔问一个问题，普通聊天产品就够了。",[14,1376,1377],{},"但如果你需要的是下面这些事情，OpenClaw 才更有意义：",[22,1379,1380,1383,1386,1389,1392],{},[25,1381,1382],{},"把同一个助手接到多个入口",[25,1384,1385],{},"让助手具备更稳定的工具调用能力",[25,1387,1388],{},"把配置、权限和数据边界掌握在自己手里",[25,1390,1391],{},"让助手长期运行，而不是每次临时打开一个网页",[25,1393,1394],{},"围绕自己的工作流持续迭代能力",[18,1396,1397],{"id":1397},"它不是什么",[14,1399,1400],{},"为了避免误解，也要明确 OpenClaw 不是什么：",[22,1402,1403,1406,1409],{},[25,1404,1405],{},"它不是开箱即用、零配置的消费级聊天应用",[25,1407,1408],{},"它不是只靠一个模型就能自动解决所有问题的“万能 AI”",[25,1410,1411],{},"它不是只讲视觉界面体验的单页面产品",[14,1413,1414],{},"如果你希望的是“注册后立即完成所有事情”，OpenClaw 反而可能显得更偏工程化。",[18,1416,1417],{"id":1417},"对中文用户最重要的理解顺序",[14,1419,1420],{},"建议按这个顺序认识 OpenClaw：",[157,1422,1423,1426,1429,1432],{},[25,1424,1425],{},"先理解它的定位和边界",[25,1427,1428],{},"再理解它的入口和渠道能力",[25,1430,1431],{},"然后看安装、onboarding 和 Control UI",[25,1433,1434],{},"最后才深入插件、hooks、模型、网关和运维",[14,1436,1437],{},"这样读起来会比一开始就钻进配置项更轻松。",[18,1439,1440],{"id":1440},"下一步建议",[14,1442,1443],{},"如果你刚开始接触 OpenClaw，推荐继续看：",[22,1445,1446,1452,1456],{},[25,1447,1448],{},[185,1449,1451],{"href":1450},"/Users/maqi/code/openclawcn/content/docs/who-is-openclaw-for.md","OpenClaw 适合哪些用户",[25,1453,1454],{},[185,1455,188],{"href":187},[25,1457,1458],{},[185,1459,366],{"href":365},{"title":66,"searchDepth":67,"depth":67,"links":1461},[1462,1463,1464,1465,1466],{"id":1351,"depth":67,"text":1351},{"id":1371,"depth":67,"text":1371},{"id":1397,"depth":67,"text":1397},{"id":1417,"depth":67,"text":1417},{"id":1440,"depth":67,"text":1440},"用中文快速理解 OpenClaw 的定位、使用方式和它与普通聊天产品的差别。",{},"/docs/what-is-openclaw",{"title":992,"description":1467},"docs/what-is-openclaw","vFO_CJUabYxZZmHmaFIXw3UpAcN5Wek52BfK3X1BmAA",{"id":1474,"title":1451,"body":1475,"category":547,"description":1621,"extension":74,"meta":1622,"navigation":76,"path":1623,"seo":1624,"stem":1625,"__hash__":1626},"docs/docs/who-is-openclaw-for.md",{"type":8,"value":1476,"toc":1607},[1477,1480,1483,1486,1490,1493,1496,1510,1514,1517,1520,1534,1538,1541,1544,1547,1551,1554,1558,1561,1565,1568,1571,1574,1585,1588,1590],[11,1478,1451],{"id":1479},"openclaw-适合哪些用户",[14,1481,1482],{},"OpenClaw 并不是“所有人都该立即使用”的产品。它的价值主要出现在你已经对 AI 助手有持续使用需求，并且希望把入口、配置和扩展能力掌握在自己手里时。",[18,1484,1485],{"id":1485},"更适合的用户",[132,1487,1489],{"id":1488},"_1-个人效率重度用户","1. 个人效率重度用户",[14,1491,1492],{},"如果你已经把 AI 用在日常工作里，并且希望它不仅能聊天，还能跨多个入口长期为你服务，那么 OpenClaw 更值得研究。",[14,1494,1495],{},"这类用户通常会关心：",[22,1497,1498,1501,1504,1507],{},[25,1499,1500],{},"能否长期运行",[25,1502,1503],{},"能否多渠道接入",[25,1505,1506],{},"能否接工具或插件",[25,1508,1509],{},"能否保留自己的配置和边界",[132,1511,1513],{"id":1512},"_2-技术团队和独立开发者","2. 技术团队和独立开发者",[14,1515,1516],{},"如果你想围绕 AI 助手做实验、做工作流、做团队内部工具，OpenClaw 的工程化结构会比消费级产品更合适。",[14,1518,1519],{},"这类场景通常重视：",[22,1521,1522,1525,1528,1531],{},[25,1523,1524],{},"可自托管",[25,1526,1527],{},"可配置",[25,1529,1530],{},"可扩展",[25,1532,1533],{},"可与现有系统整合",[132,1535,1537],{"id":1536},"_3-对隐私和控制权更敏感的用户","3. 对隐私和控制权更敏感的用户",[14,1539,1540],{},"OpenClaw 的一个核心吸引力，是让你更清楚地知道自己的入口、模型、工具和部署边界分别在哪里。",[14,1542,1543],{},"如果你不希望所有能力都锁在第三方平台里，这一点会很重要。",[18,1545,1546],{"id":1546},"不那么适合的用户",[132,1548,1550],{"id":1549},"_1-只想立刻开箱即用的人","1. 只想立刻开箱即用的人",[14,1552,1553],{},"如果你的目标只是“马上找个聊天工具来问问题”，OpenClaw 的学习成本可能偏高。",[132,1555,1557],{"id":1556},"_2-不愿意接触配置和部署的人","2. 不愿意接触配置和部署的人",[14,1559,1560],{},"即使界面做得再友好，它本质上仍然是一套需要理解结构的系统。完全不想碰配置的人，通常会更适合纯托管产品。",[132,1562,1564],{"id":1563},"_3-只需要单一网页聊天体验的人","3. 只需要单一网页聊天体验的人",[14,1566,1567],{},"如果你根本不打算接入多渠道、插件或工具，那 OpenClaw 的优势就很难真正发挥出来。",[18,1569,1570],{"id":1570},"中文用户如何判断自己需不需要",[14,1572,1573],{},"可以用下面三个问题快速判断：",[157,1575,1576,1579,1582],{},[25,1577,1578],{},"我是不是希望 AI 助手长期运行，而不是每次临时打开网页？",[25,1580,1581],{},"我是不是希望它能接入多个渠道或工具？",[25,1583,1584],{},"我是不是希望配置和边界可控，而不是完全依赖平台？",[14,1586,1587],{},"如果三个问题里至少有两个答案是“是”，那 OpenClaw 值得继续了解。",[18,1589,768],{"id":768},[22,1591,1592,1597,1602],{},[25,1593,1594,1595],{},"先看 ",[185,1596,992],{"href":991},[25,1598,1599,1600],{},"再看 ",[185,1601,188],{"href":187},[25,1603,1604,1605],{},"然后进入 ",[185,1606,802],{"href":997},{"title":66,"searchDepth":67,"depth":67,"links":1608},[1609,1614,1619,1620],{"id":1485,"depth":67,"text":1485,"children":1610},[1611,1612,1613],{"id":1488,"depth":208,"text":1489},{"id":1512,"depth":208,"text":1513},{"id":1536,"depth":208,"text":1537},{"id":1546,"depth":67,"text":1546,"children":1615},[1616,1617,1618],{"id":1549,"depth":208,"text":1550},{"id":1556,"depth":208,"text":1557},{"id":1563,"depth":208,"text":1564},{"id":1570,"depth":67,"text":1570},{"id":768,"depth":67,"text":768},"判断你是否真的需要 OpenClaw，以及它更适合哪类中文用户和团队。",{},"/docs/who-is-openclaw-for",{"title":1451,"description":1621},"docs/who-is-openclaw-for","lCRPDPH8vohYWYgFQsEoTr79xsipmuIEtas0KIv9Uqw",[1628,1670,1730,1792,1842,1907,1951,2014],{"id":1629,"title":1630,"body":1631,"category":1662,"date":1663,"description":1664,"extension":74,"meta":1665,"navigation":76,"path":1666,"seo":1667,"stem":1668,"__hash__":1669},"news/news/best-practices-launch.md","最佳实践专题已上线",{"type":8,"value":1632,"toc":1658},[1633,1635,1638,1641,1652,1655],[11,1634,1630],{"id":1630},[14,1636,1637],{},"在第 3 步里，优先补充的是内容型深度页面，而不是复杂功能。",[18,1639,1640],{"id":1640},"已完成",[22,1642,1643,1646,1649],{},[25,1644,1645],{},"最佳实践列表页",[25,1647,1648],{},"最佳实践详情页",[25,1650,1651],{},"搜索接入最佳实践内容",[18,1653,1654],{"id":1654},"意义",[14,1656,1657],{},"这让站点开始具备“从介绍站点走向知识沉淀”的基础结构。",{"title":66,"searchDepth":67,"depth":67,"links":1659},[1660,1661],{"id":1640,"depth":67,"text":1640},{"id":1654,"depth":67,"text":1654},"站点更新","2026-03-09","第 3 步开始补充最佳实践列表与详情页，站点内容开始从说明型页面走向专题沉淀。",{},"/news/best-practices-launch",{"title":1630,"description":1664},"news/best-practices-launch","5E5X7dJqfS1XlUSC2VlyHeoytDjN0u2prlPh24ce934",{"id":1671,"title":1672,"body":1673,"category":1662,"date":1663,"description":1724,"extension":74,"meta":1725,"navigation":76,"path":1726,"seo":1727,"stem":1728,"__hash__":1729},"news/news/community-rss-launch.md","社区互动与订阅链路补齐",{"type":8,"value":1674,"toc":1720},[1675,1677,1680,1683,1698,1701],[11,1676,1672],{"id":1672},[14,1678,1679],{},"这次推进的重点不再是补单一页面，而是把内容更新之后的后续动作串起来。",[18,1681,1682],{"id":1682},"已补齐",[22,1684,1685,1688,1691],{},[25,1686,1687],{},"社区页新增更明确的参与路径",[25,1689,1690],{},"新闻详情页和最佳实践详情页补上统一互动入口",[25,1692,1693,1694,1697],{},"新增 ",[588,1695,1696],{},"/rss.xml"," 更新订阅源",[18,1699,1700],{"id":1700},"现在可以怎么验证",[157,1702,1703,1709,1712,1715],{},[25,1704,623,1705,1708],{},[588,1706,1707],{},"/community"," 查看参与路径和 RSS 入口",[25,1710,1711],{},"打开任意新闻详情页，确认页面底部有反馈、社区和订阅入口",[25,1713,1714],{},"打开任意最佳实践详情页，确认页面底部有相同的运营 CTA",[25,1716,623,1717,1719],{},[588,1718,1696],{},"，确认可以看到新闻和最佳实践条目",{"title":66,"searchDepth":67,"depth":67,"links":1721},[1722,1723],{"id":1682,"depth":67,"text":1682},{"id":1700,"depth":67,"text":1700},"社区页、内容详情页和 RSS 更新订阅已接通，站点开始具备长期运营入口。",{},"/news/community-rss-launch",{"title":1672,"description":1724},"news/community-rss-launch","ChWj9KkHkYCEsQQkwUozj-9W04XKnahPmll63mnUa1s",{"id":1731,"title":1732,"body":1733,"category":1785,"date":1663,"description":1786,"extension":74,"meta":1787,"navigation":76,"path":1788,"seo":1789,"stem":1790,"__hash__":1791},"news/news/content-seeding-batch-1.md","冷启动内容首批专题已补充",{"type":8,"value":1734,"toc":1780},[1735,1737,1740,1743,1757,1760,1763,1766,1769],[11,1736,1732],{"id":1732},[14,1738,1739],{},"这次不是只补一两篇说明页，而是开始系统性地把 OpenClaw 中文内容做厚。",[18,1741,1742],{"id":1742},"首批新增方向",[22,1744,1745,1748,1751,1754],{},[25,1746,1747],{},"产品介绍与定位",[25,1749,1750],{},"Onboarding 与 Control UI",[25,1752,1753],{},"Channels、Hooks 与安全基础",[25,1755,1756],{},"更新跟踪方法",[18,1758,1759],{"id":1759},"这批内容的意义",[14,1761,1762],{},"站点现在不再只是“有首页、有列表”，而是开始具备连续阅读能力。用户从第一次进入首页开始，就能一路读到产品定位、能力结构、入门顺序和后续更新方法。",[18,1764,1765],{"id":1765},"下一步",[14,1767,1768],{},"接下来会继续补：",[22,1770,1771,1774,1777],{},[25,1772,1773],{},"版本更新解读",[25,1775,1776],{},"常见问题与排错",[25,1778,1779],{},"不同平台与渠道的专题说明",{"title":66,"searchDepth":67,"depth":67,"links":1781},[1782,1783,1784],{"id":1742,"depth":67,"text":1742},{"id":1759,"depth":67,"text":1759},{"id":1765,"depth":67,"text":1765},"内容建设","产品介绍、快速开始、功能专题与更新跟踪的首批中文内容已开始铺量，文档中心不再只有骨架。",{},"/news/content-seeding-batch-1",{"title":1732,"description":1786},"news/content-seeding-batch-1","nphwITbUAGXW_nN0-fPHWgVulcZELbn2I_VCCETDbN0",{"id":1793,"title":1794,"body":1795,"category":1662,"date":1835,"description":1836,"extension":74,"meta":1837,"navigation":76,"path":1838,"seo":1839,"stem":1840,"__hash__":1841},"news/news/content-structure.md","中文资料结构完成首版梳理",{"type":8,"value":1796,"toc":1831},[1797,1799,1802,1804,1818,1820],[11,1798,1794],{"id":1794},[14,1800,1801],{},"这次调整的重点是把站点目标重新收拢到“介绍 OpenClaw 本身”，而不是介绍本站如何部署。",[18,1803,1640],{"id":1640},[22,1805,1806,1809,1812,1815],{},[25,1807,1808],{},"首页文案重新围绕 OpenClaw 本身整理",[25,1810,1811],{},"文档目录改为快速入门、安装与社区支持",[25,1813,1814],{},"新闻内容开始记录中文官网的阶段推进",[25,1816,1817],{},"GitHub 和社区入口保留在站点结构中",[18,1819,1765],{"id":1765},[22,1821,1822,1825,1828],{},[25,1823,1824],{},"建立搜索与反馈接口",[25,1826,1827],{},"扩充安装与使用教程",[25,1829,1830],{},"建立更完整的中文社区支持页面",{"title":66,"searchDepth":67,"depth":67,"links":1832},[1833,1834],{"id":1640,"depth":67,"text":1640},{"id":1765,"depth":67,"text":1765},"2026-03-06","首页文案、文档目录和社区入口开始围绕中文用户的理解路径重新组织。",{},"/news/content-structure",{"title":1794,"description":1836},"news/content-structure","El2lvki7PUq-G8e0qBdusm4vCCAEHGqfzwA8hb7bgAA",{"id":1843,"title":1844,"body":1845,"category":1662,"date":1900,"description":1901,"extension":74,"meta":1902,"navigation":76,"path":1903,"seo":1904,"stem":1905,"__hash__":1906},"news/news/demo-ready-step2.md","第 2 步演示能力继续增强",{"type":8,"value":1846,"toc":1896},[1847,1850,1853,1856,1870,1872],[11,1848,1844],{"id":1849},"第-2-步演示能力继续增强",[14,1851,1852],{},"这次补的不是新方向，而是把第 2 步原本已经存在的能力做得更像一个可以演示的产品切片。",[18,1854,1855],{"id":1855},"新增内容",[22,1857,1858,1861,1864,1867],{},[25,1859,1860],{},"搜索关键词高亮",[25,1862,1863],{},"搜索无结果空状态",[25,1865,1866],{},"FAQ 页面",[25,1868,1869],{},"邮箱订阅表单与接口",[18,1871,1700],{"id":1700},[157,1873,1874,1880,1883,1889],{},[25,1875,623,1876,1879],{},[588,1877,1878],{},"/search?q=安装"," 查看高亮结果",[25,1881,1882],{},"搜索一个不存在的词，确认出现空状态",[25,1884,623,1885,1888]
[{"data":1,"prerenderedAt":1627},["ShallowReactive",2],{"docs:index":3},[4,145,296,462,624,783,937,1081,1225,1290,1386,1453,1580],{"id":5,"title":6,"body":7,"category":136,"description":137,"extension":138,"meta":139,"navigation":140,"path":141,"seo":142,"stem":143,"__hash__":144},"docs/docs/control-ui.md","Control UI 是什么",{"type":8,"value":9,"toc":122},"minimark",[10,14,18,22,25,28,44,47,50,58,61,64,67,72,75,79,82,86,89,92,95,98,101],[11,12,6],"h1",{"id":13},"control-ui-是什么",[15,16,17],"p",{},"OpenClaw 不只是靠消息入口工作。官方文档单独强调了 Control UI，这说明它在整个系统里承担的是“可见、可管、可检查”的角色。",[19,20,21],"h2",{"id":21},"可以把它理解成什么",[15,23,24],{},"如果说聊天渠道更像是日常使用入口，那么 Control UI 更像是系统管理入口。",[15,26,27],{},"它更适合做这些事情：",[29,30,31,35,38,41],"ul",{},[32,33,34],"li",{},"看当前系统是否正常运行",[32,36,37],{},"检查初始化是否完成",[32,39,40],{},"观察能力是否已经接通",[32,42,43],{},"调整一些运行与管理相关配置",[19,45,46],{"id":46},"它和聊天入口的区别",[15,48,49],{},"很多新用户会把 Control UI 和聊天窗口混为一谈。更准确的理解应该是：",[29,51,52,55],{},[32,53,54],{},"聊天入口偏“使用”",[32,56,57],{},"Control UI 偏“管理与观察”",[15,59,60],{},"这也是为什么第一次部署和排错时，Control UI 往往更重要。",[19,62,63],{"id":63},"什么时候最该打开它",[15,65,66],{},"推荐在以下阶段优先查看：",[68,69,71],"h3",{"id":70},"_1-首次安装完成后","1. 首次安装完成后",[15,73,74],{},"确认最小链路是否正常。",[68,76,78],{"id":77},"_2-开始扩展新渠道时","2. 开始扩展新渠道时",[15,80,81],{},"查看系统结构是否已经完整接通，而不是只看单个渠道报不报错。",[68,83,85],{"id":84},"_3-进行排错时","3. 进行排错时",[15,87,88],{},"如果你只盯着一个外部消息入口，很容易把问题误判成渠道问题。Control UI 更适合帮助你理解问题到底出在哪一层。",[19,90,91],{"id":91},"中文用户最容易忽略的一点",[15,93,94],{},"很多人第一次接触 OpenClaw 时，只想尽快进入“聊天”。但从长期使用来看，Control UI 往往才是你真正理解系统结构的地方。",[15,96,97],{},"它不是锦上添花的面板，而是把 OpenClaw 从“单个聊天体验”升级成“可管理系统”的关键入口。",[19,99,100],{"id":100},"下一步推荐",[29,102,103,110,116],{},[32,104,105],{},[106,107,109],"a",{"href":108},"/Users/maqi/code/openclawcn/content/docs/onboarding-guide.md","Onboarding 引导流程说明",[32,111,112],{},[106,113,115],{"href":114},"/Users/maqi/code/openclawcn/content/docs/channels-overview.md","渠道能力概览",[32,117,118],{},[106,119,121],{"href":120},"/Users/maqi/code/openclawcn/content/docs/safety-basics.md","安全配置基础",{"title":123,"searchDepth":124,"depth":124,"links":125},"",2,[126,127,128,134,135],{"id":21,"depth":124,"text":21},{"id":46,"depth":124,"text":46},{"id":63,"depth":124,"text":63,"children":129},[130,132,133],{"id":70,"depth":131,"text":71},3,{"id":77,"depth":131,"text":78},{"id":84,"depth":131,"text":85},{"id":91,"depth":124,"text":91},{"id":100,"depth":124,"text":100},"入门","理解 OpenClaw 的控制界面在整个系统里的作用，以及它适合处理哪些任务。","md",{},true,"/docs/control-ui",{"title":6,"description":137},"docs/control-ui","QqKzTSzjJjBiU4DxbctIEpp3HyXzKzqyfWKTP2O2oxI",{"id":146,"title":147,"body":148,"category":289,"description":290,"extension":138,"meta":291,"navigation":140,"path":292,"seo":293,"stem":294,"__hash__":295},"docs/docs/hooks-overview.md","Hooks 能做什么",{"type":8,"value":149,"toc":278},[150,153,156,160,163,166,177,181,184,187,201,204,207,222,226,229,243,246,250,253,256,259,262],[11,151,147],{"id":152},"hooks-能做什么",[15,154,155],{},"从官方文档结构看，hooks 是 OpenClaw 里单独值得理解的一层。它的意义不只是“有一个技术能力”，而是给系统留出自动化扩展点。",[19,157,159],{"id":158},"可以把-hooks-理解成什么","可以把 hooks 理解成什么",[15,161,162],{},"更容易理解的说法是：hooks 是系统在某些关键阶段触发额外动作的机制。",[15,164,165],{},"它的价值在于：",[29,167,168,171,174],{},[32,169,170],{},"把固定流程自动化",[32,172,173],{},"把系统和外部逻辑接起来",[32,175,176],{},"减少人工重复操作",[19,178,180],{"id":179},"为什么这对-openclaw-很重要","为什么这对 OpenClaw 很重要",[15,182,183],{},"如果 OpenClaw 只是一个聊天窗口，hooks 的价值并不会这么明显。",[15,185,186],{},"但它是一个长期运行、可扩展、可接渠道的系统，所以 hooks 可以承担很多“系统级动作”：",[29,188,189,192,195,198],{},[32,190,191],{},"配置后的补充流程",[32,193,194],{},"某些事件发生后的自动响应",[32,196,197],{},"与外部服务的衔接",[32,199,200],{},"运维层面的触发动作",[19,202,203],{"id":203},"冷启动阶段该怎么用它",[15,205,206],{},"在内容站冷启动阶段，不建议一开始就把 hooks 写得特别复杂。更稳的做法是：",[208,209,210,213,216,219],"ol",{},[32,211,212],{},"先理解它的角色",[32,214,215],{},"只保留最小自动化",[32,217,218],{},"跑通一条稳定链路",[32,220,221],{},"再逐步增加复杂动作",[19,223,225],{"id":224},"什么情况下值得引入-hooks","什么情况下值得引入 hooks",[15,227,228],{},"如果你已经出现这些需求，就说明 hooks 值得研究：",[29,230,231,234,237,240],{},[32,232,233],{},"某些步骤总是重复做",[32,235,236],{},"希望特定事件发生后自动执行动作",[32,238,239],{},"需要把 OpenClaw 和外部流程接起来",[32,241,242],{},"想减少人工检查与人工同步",[19,244,245],{"id":245},"中文用户常见误区",[68,247,249],{"id":248},"一上来就写很多-hooks","一上来就写很多 hooks",[15,251,252],{},"这样会让系统更难排错，也更难区分问题到底出在哪一层。",[68,254,255],{"id":255},"不理解触发边界",[15,257,258],{},"如果只知道“能挂逻辑”，但不知道“什么时候触发、影响哪一层”，后续维护成本会很高。",[19,260,261],{"id":261},"推荐阅读顺序",[29,263,264,270,274],{},[32,265,266],{},[106,267,269],{"href":268},"/Users/maqi/code/openclawcn/content/docs/core-capabilities.md","OpenClaw 核心能力总览",[32,271,272],{},[106,273,115],{"href":114},[32,275,276],{},[106,277,121],{"href":120},{"title":123,"searchDepth":124,"depth":124,"links":279},[280,281,282,283,284,288],{"id":158,"depth":124,"text":159},{"id":179,"depth":124,"text":180},{"id":203,"depth":124,"text":203},{"id":224,"depth":124,"text":225},{"id":245,"depth":124,"text":245,"children":285},[286,287],{"id":248,"depth":131,"text":249},{"id":255,"depth":131,"text":255},{"id":261,"depth":124,"text":261},"功能","从中文用户角度理解 OpenClaw 里的 hooks，不把它只看成技术细节，而看成自动化扩展点。",{},"/docs/hooks-overview",{"title":147,"description":290},"docs/hooks-overview","LLFN_OZqz0qqSpWeESk0Bkyb0wYzztVgfHpcMdOYqWc",{"id":297,"title":109,"body":298,"category":136,"description":456,"extension":138,"meta":457,"navigation":140,"path":458,"seo":459,"stem":460,"__hash__":461},"docs/docs/onboarding-guide.md",{"type":8,"value":299,"toc":442},[300,303,306,310,313,324,327,330,333,337,340,351,355,358,369,373,376,390,392,395,398,402,405,409,412,415],[11,301,109],{"id":302},"onboarding-引导流程说明",[15,304,305],{},"从官方文档结构看，OpenClaw 非常重视 onboarding。这个信息很关键，因为它意味着官方并不要求你第一次使用就理解全部内部结构，而是希望你先完成一轮受控的初始化。",[19,307,309],{"id":308},"为什么-onboarding-很重要","为什么 onboarding 很重要",[15,311,312],{},"对中文用户来说，第一次接触 OpenClaw 通常会遇到三个问题：",[29,314,315,318,321],{},[32,316,317],{},"不清楚先从哪里开始",[32,319,320],{},"不知道 Control UI、渠道和工具之间是什么关系",[32,322,323],{},"不确定哪些配置是现在就必须做的",[15,325,326],{},"onboarding 的价值，就是把这三个问题的顺序理清楚。",[19,328,329],{"id":329},"第一次配置最应该关注什么",[15,331,332],{},"建议把注意力放在下面几件事：",[68,334,336],{"id":335},"_1-先确认运行环境","1. 先确认运行环境",[15,338,339],{},"不要急着扩展渠道和高级能力，先确认：",[29,341,342,345,348],{},[32,343,344],{},"当前系统环境能正常跑起来",[32,346,347],{},"基础安装没有报错",[32,349,350],{},"最小链路已经能工作",[68,352,354],{"id":353},"_2-再确认入口","2. 再确认入口",[15,356,357],{},"第一次使用时，最重要的是知道自己准备通过什么入口和 OpenClaw 交互：",[29,359,360,363,366],{},[32,361,362],{},"是先通过 Control UI",[32,364,365],{},"还是先通过某个消息渠道",[32,367,368],{},"还是先从本地测试链路开始",[68,370,372],{"id":371},"_3-最后再扩展","3. 最后再扩展",[15,374,375],{},"完成第一轮 onboarding 后，再逐步进入：",[29,377,378,381,384,387],{},[32,379,380],{},"更多渠道",[32,382,383],{},"更多工具",[32,385,386],{},"hooks",[32,388,389],{},"安全与远程访问",[19,391,245],{"id":245},[68,393,394],{"id":394},"一开始就想把所有能力都接上",[15,396,397],{},"这会直接把第一次体验变成排错现场。更好的方法，是先跑通一条最小链路。",[68,399,401],{"id":400},"把-onboarding-当成一次性的步骤","把 onboarding 当成一次性的步骤",[15,403,404],{},"实际上，onboarding 更像“第一轮可控配置”，它不是终点，而是后续迭代的起点。",[68,406,408],{"id":407},"只关注界面不关注边界","只关注界面，不关注边界",[15,410,411],{},"OpenClaw 不是只有界面体验，入口、权限、模型、渠道和部署边界要一起看。",[19,413,414],{"id":414},"推荐的第一次使用顺序",[208,416,417,424,430,433,439],{},[32,418,419,420],{},"阅读 ",[106,421,423],{"href":422},"/Users/maqi/code/openclawcn/content/docs/what-is-openclaw.md","OpenClaw 是什么",[32,425,419,426],{},[106,427,429],{"href":428},"/Users/maqi/code/openclawcn/content/docs/installation.md","安装与环境",[32,431,432],{},"完成最小 onboarding",[32,434,435,436],{},"打开 ",[106,437,6],{"href":438},"/Users/maqi/code/openclawcn/content/docs/control-ui.md",[32,440,441],{},"再决定是否扩展渠道和 hooks",{"title":123,"searchDepth":124,"depth":124,"links":443},[444,445,450,455],{"id":308,"depth":124,"text":309},{"id":329,"depth":124,"text":329,"children":446},[447,448,449],{"id":335,"depth":131,"text":336},{"id":353,"depth":131,"text":354},{"id":371,"depth":131,"text":372},{"id":245,"depth":124,"text":245,"children":451},[452,453,454],{"id":394,"depth":131,"text":394},{"id":400,"depth":131,"text":401},{"id":407,"depth":131,"text":408},{"id":414,"depth":124,"text":414},"为什么 OpenClaw 要强调 onboarding，以及中文用户第一次配置时应该关注什么。",{},"/docs/onboarding-guide",{"title":109,"description":456},"docs/onboarding-guide","m645noqiBiXgao9_8YSrppzCHN1kfbjsGphqf2SguHg",{"id":463,"title":423,"body":464,"category":617,"description":618,"extension":138,"meta":619,"navigation":140,"path":620,"seo":621,"stem":622,"__hash__":623},"docs/docs/what-is-openclaw.md",{"type":8,"value":465,"toc":610},[466,469,472,475,499,502,505,516,519,522,525,528,545,548,551,562,565,568,571,585,588,591,594],[11,467,423],{"id":468},"openclaw-是什么",[15,470,471],{},"OpenClaw 可以理解成一套“可自行托管、可扩展、可接入多渠道”的个人 AI 助手系统。它不是单独一个聊天窗口，而更像一个可以持续运行、持续接消息、持续调用工具的助手框架。",[15,473,474],{},"对中文用户来说，理解 OpenClaw 最重要的不是先记住所有功能，而是先抓住三个关键词：",[29,476,477,485,492],{},[32,478,479,480,484],{},"它是 ",[481,482,483],"strong",{},"自己的助手系统","，不是某个平台托管给你的封闭产品",[32,486,487,488,491],{},"它强调 ",[481,489,490],{},"渠道接入和扩展能力","，不只服务于一个网页聊天框",[32,493,494,495,498],{},"它更接近 ",[481,496,497],{},"可运行的工作流与代理系统","，而不是只会回答问题的聊天机器人",[19,500,501],{"id":501},"可以把它看成什么",[15,503,504],{},"更容易理解的方式，是把 OpenClaw 看成三层结构：",[208,506,507,510,513],{},[32,508,509],{},"最外层是你接触它的入口，比如不同聊天渠道、网页控制台和 API",[32,511,512],{},"中间层是路由、记忆、工具、插件和模型等运行能力",[32,514,515],{},"最底层是你自己的部署环境和配置边界",[15,517,518],{},"这意味着 OpenClaw 的价值，不只是“能聊”，而是“能接、能管、能扩展、能长期运行”。",[19,520,521],{"id":521},"它解决什么问题",[15,523,524],{},"如果你只是偶尔问一个问题，普通聊天产品就够了。",[15,526,527],{},"但如果你需要的是下面这些事情，OpenClaw 才更有意义：",[29,529,530,533,536,539,542],{},[32,531,532],{},"把同一个助手接到多个入口",[32,534,535],{},"让助手具备更稳定的工具调用能力",[32,537,538],{},"把配置、权限和数据边界掌握在自己手里",[32,540,541],{},"让助手长期运行，而不是每次临时打开一个网页",[32,543,544],{},"围绕自己的工作流持续迭代能力",[19,546,547],{"id":547},"它不是什么",[15,549,550],{},"为了避免误解，也要明确 OpenClaw 不是什么：",[29,552,553,556,559],{},[32,554,555],{},"它不是开箱即用、零配置的消费级聊天应用",[32,557,558],{},"它不是只靠一个模型就能自动解决所有问题的“万能 AI”",[32,560,561],{},"它不是只讲视觉界面体验的单页面产品",[15,563,564],{},"如果你希望的是“注册后立即完成所有事情”，OpenClaw 反而可能显得更偏工程化。",[19,566,567],{"id":567},"对中文用户最重要的理解顺序",[15,569,570],{},"建议按这个顺序认识 OpenClaw：",[208,572,573,576,579,582],{},[32,574,575],{},"先理解它的定位和边界",[32,577,578],{},"再理解它的入口和渠道能力",[32,580,581],{},"然后看安装、onboarding 和 Control UI",[32,583,584],{},"最后才深入插件、hooks、模型、网关和运维",[15,586,587],{},"这样读起来会比一开始就钻进配置项更轻松。",[19,589,590],{"id":590},"下一步建议",[15,592,593],{},"如果你刚开始接触 OpenClaw，推荐继续看：",[29,595,596,602,606],{},[32,597,598],{},[106,599,601],{"href":600},"/Users/maqi/code/openclawcn/content/docs/who-is-openclaw-for.md","OpenClaw 适合哪些用户",[32,603,604],{},[106,605,269],{"href":268},[32,607,608],{},[106,609,109],{"href":108},{"title":123,"searchDepth":124,"depth":124,"links":611},[612,613,614,615,616],{"id":501,"depth":124,"text":501},{"id":521,"depth":124,"text":521},{"id":547,"depth":124,"text":547},{"id":567,"depth":124,"text":567},{"id":590,"depth":124,"text":590},"产品","用中文快速理解 OpenClaw 的定位、使用方式和它与普通聊天产品的差别。",{},"/docs/what-is-openclaw",{"title":423,"description":618},"docs/what-is-openclaw","vFO_CJUabYxZZmHmaFIXw3UpAcN5Wek52BfK3X1BmAA",{"id":625,"title":269,"body":626,"category":617,"description":777,"extension":138,"meta":778,"navigation":140,"path":779,"seo":780,"stem":781,"__hash__":782},"docs/docs/core-capabilities.md",{"type":8,"value":627,"toc":767},[628,631,634,638,641,644,655,659,662,665,679,683,686,689,693,696,699,703,706,717,720,724,727,730,733,736,750,752],[11,629,269],{"id":630},"openclaw-核心能力总览",[15,632,633],{},"官方文档当前把 OpenClaw 的能力组织成若干块：开始使用、渠道、agents、tools、models、platforms、gateway 与运维、帮助与参考。对中文用户来说，这说明它不是单一功能，而是一整套围绕助手运行的结构。",[19,635,637],{"id":636},"_1-渠道接入","1. 渠道接入",[15,639,640],{},"OpenClaw 的一大特点是渠道能力。你不一定只通过一个网页和它交互，而可能通过不同消息入口与同一个助手体系连接。",[15,642,643],{},"这带来的意义是：",[29,645,646,649,652],{},[32,647,648],{},"入口不再单一",[32,650,651],{},"助手能力更贴近日常通信方式",[32,653,654],{},"同一套配置和逻辑可以服务多个使用场景",[19,656,658],{"id":657},"_2-控制界面","2. 控制界面",[15,660,661],{},"除了聊天渠道，OpenClaw 还提供 Control UI 这类更适合管理和观察系统状态的入口。",[15,663,664],{},"这类入口通常更适合：",[29,666,667,670,673,676],{},[32,668,669],{},"首次完成配置",[32,671,672],{},"查看系统是否正常运行",[32,674,675],{},"调整能力和运行参数",[32,677,678],{},"做排查和检查",[19,680,682],{"id":681},"_3-引导与配置","3. 引导与配置",[15,684,685],{},"OpenClaw 官方文档强调 onboarding 和 setup 路径，这说明它希望用户先经过一轮可理解的初始化，而不是一开始就手写全部配置。",[15,687,688],{},"这对冷启动很重要，因为它降低了第一次使用时的理解成本。",[19,690,692],{"id":691},"_4-工具与扩展","4. 工具与扩展",[15,694,695],{},"OpenClaw 的价值还在于它不是只调用模型。它还包含工具、hooks、平台能力以及后续可扩展的结构。",[15,697,698],{},"从中文站点角度看，这一层是后续最值得持续扩写的内容，因为很多用户真正卡住的地方，往往都在“怎么接进去”和“怎么安全使用”。",[19,700,702],{"id":701},"_5-模型与运行边界","5. 模型与运行边界",[15,704,705],{},"模型并不是 OpenClaw 的全部，但它是运行体系的一部分。更准确地说，OpenClaw 关心的是：",[29,707,708,711,714],{},[32,709,710],{},"模型从哪里来",[32,712,713],{},"怎么和工具、渠道、配置结合",[32,715,716],{},"如何在自己的部署边界里运行",[15,718,719],{},"这也是它和单纯聊天网页最大的区别之一。",[19,721,723],{"id":722},"_6-运维与网关","6. 运维与网关",[15,725,726],{},"当你开始把它长期运行起来，就会进入 gateway、远程访问、安全和运维问题。",[15,728,729],{},"很多用户会在这一层意识到：OpenClaw 不只是一个“AI 功能集合”，而是一套需要被管理的长期系统。",[19,731,732],{"id":732},"建议的理解顺序",[15,734,735],{},"最推荐的顺序是：",[208,737,738,741,744,747],{},[32,739,740],{},"先理解定位",[32,742,743],{},"再理解渠道和 Control UI",[32,745,746],{},"再理解 onboarding、工具和 hooks",[32,748,749],{},"最后再进入平台、模型和运维",[19,751,100],{"id":100},[29,753,754,758,762],{},[32,755,756],{},[106,757,115],{"href":114},[32,759,760],{},[106,761,6],{"href":438},[32,763,764],{},[106,765,147],{"href":766},"/Users/maqi/code/openclawcn/content/docs/hooks-overview.md",{"title":123,"searchDepth":124,"depth":124,"links":768},[769,770,771,772,773,774,775,776],{"id":636,"depth":124,"text":637},{"id":657,"depth":124,"text":658},{"id":681,"depth":124,"text":682},{"id":691,"depth":124,"text":692},{"id":701,"depth":124,"text":702},{"id":722,"depth":124,"text":723},{"id":732,"depth":124,"text":732},{"id":100,"depth":124,"text":100},"用一页理解 OpenClaw 当前最重要的能力结构，包括渠道、控制台、扩展和运行边界。",{},"/docs/core-capabilities",{"title":269,"description":777},"docs/core-capabilities","FM4_PB6GOMfqWPy5L5tZtwb3pOq94AiZalY-duOnqQg",{"id":784,"title":601,"body":785,"category":617,"description":931,"extension":138,"meta":932,"navigation":140,"path":933,"seo":934,"stem":935,"__hash__":936},"docs/docs/who-is-openclaw-for.md",{"type":8,"value":786,"toc":917},[787,790,793,796,800,803,806,820,824,827,830,844,848,851,854,857,861,864,868,871,875,878,881,884,895,898,900],[11,788,601],{"id":789},"openclaw-适合哪些用户",[15,791,792],{},"OpenClaw 并不是“所有人都该立即使用”的产品。它的价值主要出现在你已经对 AI 助手有持续使用需求，并且希望把入口、配置和扩展能力掌握在自己手里时。",[19,794,795],{"id":795},"更适合的用户",[68,797,799],{"id":798},"_1-个人效率重度用户","1. 个人效率重度用户",[15,801,802],{},"如果你已经把 AI 用在日常工作里，并且希望它不仅能聊天，还能跨多个入口长期为你服务，那么 OpenClaw 更值得研究。",[15,804,805],{},"这类用户通常会关心：",[29,807,808,811,814,817],{},[32,809,810],{},"能否长期运行",[32,812,813],{},"能否多渠道接入",[32,815,816],{},"能否接工具或插件",[32,818,819],{},"能否保留自己的配置和边界",[68,821,823],{"id":822},"_2-技术团队和独立开发者","2. 技术团队和独立开发者",[15,825,826],{},"如果你想围绕 AI 助手做实验、做工作流、做团队内部工具，OpenClaw 的工程化结构会比消费级产品更合适。",[15,828,829],{},"这类场景通常重视：",[29,831,832,835,838,841],{},[32,833,834],{},"可自托管",[32,836,837],{},"可配置",[32,839,840],{},"可扩展",[32,842,843],{},"可与现有系统整合",[68,845,847],{"id":846},"_3-对隐私和控制权更敏感的用户","3. 对隐私和控制权更敏感的用户",[15,849,850],{},"OpenClaw 的一个核心吸引力，是让你更清楚地知道自己的入口、模型、工具和部署边界分别在哪里。",[15,852,853],{},"如果你不希望所有能力都锁在第三方平台里，这一点会很重要。",[19,855,856],{"id":856},"不那么适合的用户",[68,858,860],{"id":859},"_1-只想立刻开箱即用的人","1. 只想立刻开箱即用的人",[15,862,863],{},"如果你的目标只是“马上找个聊天工具来问问题”，OpenClaw 的学习成本可能偏高。",[68,865,867],{"id":866},"_2-不愿意接触配置和部署的人","2. 不愿意接触配置和部署的人",[15,869,870],{},"即使界面做得再友好，它本质上仍然是一套需要理解结构的系统。完全不想碰配置的人，通常会更适合纯托管产品。",[68,872,874],{"id":873},"_3-只需要单一网页聊天体验的人","3. 只需要单一网页聊天体验的人",[15,876,877],{},"如果你根本不打算接入多渠道、插件或工具，那 OpenClaw 的优势就很难真正发挥出来。",[19,879,880],{"id":880},"中文用户如何判断自己需不需要",[15,882,883],{},"可以用下面三个问题快速判断：",[208,885,886,889,892],{},[32,887,888],{},"我是不是希望 AI 助手长期运行，而不是每次临时打开网页？",[32,890,891],{},"我是不是希望它能接入多个渠道或工具？",[32,893,894],{},"我是不是希望配置和边界可控，而不是完全依赖平台？",[15,896,897],{},"如果三个问题里至少有两个答案是“是”，那 OpenClaw 值得继续了解。",[19,899,261],{"id":261},[29,901,902,907,912],{},[32,903,904,905],{},"先看 ",[106,906,423],{"href":422},[32,908,909,910],{},"再看 ",[106,911,269],{"href":268},[32,913,914,915],{},"然后进入 ",[106,916,429],{"href":428},{"title":123,"searchDepth":124,"depth":124,"links":918},[919,924,929,930],{"id":795,"depth":124,"text":795,"children":920},[921,922,923],{"id":798,"depth":131,"text":799},{"id":822,"depth":131,"text":823},{"id":846,"depth":131,"text":847},{"id":856,"depth":124,"text":856,"children":925},[926,927,928],{"id":859,"depth":131,"text":860},{"id":866,"depth":131,"text":867},{"id":873,"depth":131,"text":874},{"id":880,"depth":124,"text":880},{"id":261,"depth":124,"text":261},"判断你是否真的需要 OpenClaw，以及它更适合哪类中文用户和团队。",{},"/docs/who-is-openclaw-for",{"title":601,"description":931},"docs/who-is-openclaw-for","lCRPDPH8vohYWYgFQsEoTr79xsipmuIEtas0KIv9Uqw",{"id":938,"title":939,"body":940,"category":1074,"description":1075,"extension":138,"meta":1076,"navigation":140,"path":1077,"seo":1078,"stem":1079,"__hash__":1080},"docs/docs/release-tracking.md","如何持续跟踪 OpenClaw 更新",{"type":8,"value":941,"toc":1063},[942,945,948,951,954,965,968,971,974,977,980,983,994,997,1000,1004,1012,1016,1022,1026,1029,1032,1043,1046,1049,1060],[11,943,939],{"id":944},"如何持续跟踪-openclaw-更新",[15,946,947],{},"对于 OpenClaw 这种持续演进的系统，冷启动阶段除了补基础内容，更重要的是建立“持续跟踪更新”的方法。否则内容很快就会过时。",[19,949,950],{"id":950},"推荐关注的官方入口",[15,952,953],{},"最值得长期关注的有三类：",[29,955,956,959,962],{},[32,957,958],{},"官方文档",[32,960,961],{},"GitHub 仓库",[32,963,964],{},"GitHub Releases",[15,966,967],{},"其中，Releases 最适合看版本变化，官方文档最适合看能力结构和使用方式，仓库则最适合补充真实讨论和实现方向。",[19,969,970],{"id":970},"为什么不能只看一个入口",[15,972,973],{},"如果只看文档，你可能会错过版本变化节奏。",[15,975,976],{},"如果只看 release，你又可能不知道这些变化应该怎么被用户理解。",[15,978,979],{},"如果只看 issue，你会陷入局部问题，反而看不清主线。",[15,981,982],{},"更稳妥的方式，是把三类信息组合起来：",[208,984,985,988,991],{},[32,986,987],{},"先看 release 发生了什么",[32,989,990],{},"再看官方 docs 如何组织能力",[32,992,993],{},"最后看社区里哪些问题最常见",[19,995,996],{"id":996},"中文站点怎么把更新转成内容",[15,998,999],{},"最推荐的做法是把更新分成三类：",[68,1001,1003],{"id":1002},"_1-版本速览","1. 版本速览",[15,1005,1006,1007,1011],{},"用于 ",[1008,1009,1010],"code",{},"/news","，快速回答“这次版本主要发生了什么”。",[68,1013,1015],{"id":1014},"_2-功能解读","2. 功能解读",[15,1017,1006,1018,1021],{},[1008,1019,1020],{},"/docs","，把某个功能做成长期可读的中文说明。",[68,1023,1025],{"id":1024},"_3-升级提醒","3. 升级提醒",[15,1027,1028],{},"用于最佳实践或 FAQ，回答“我需不需要马上改配置、有哪些风险”。",[19,1030,1031],{"id":1031},"建议的跟踪频率",[29,1033,1034,1037,1040],{},[32,1035,1036],{},"每周至少看一次 releases",[32,1038,1039],{},"每次重要版本后补一篇中文摘要",[32,1041,1042],{},"每次能力结构变化时补对应文档页",[19,1044,1045],{"id":1045},"当前最实用的做法",[15,1047,1048],{},"如果你还不想搭复杂自动化，先做下面三件事就够：",[208,1050,1051,1054,1057],{},[32,1052,1053],{},"订阅 RSS 或 GitHub Release 动态",[32,1055,1056],{},"每周看一次官方 docs 目录变化",[32,1058,1059],{},"把重要更新同步进中文新闻页",[15,1061,1062],{},"这样就能让站点内容保持基本的新鲜度。",{"title":123,"searchDepth":124,"depth":124,"links":1064},[1065,1066,1067,1072,1073],{"id":950,"depth":124,"text":950},{"id":970,"depth":124,"text":970},{"id":996,"depth":124,"text":996,"children":1068},[1069,1070,1071],{"id":1002,"depth":131,"text":1003},{"id":1014,"depth":131,"text":1015},{"id":1024,"depth":131,"text":1025},{"id":1031,"depth":124,"text":1031},{"id":1045,"depth":124,"text":1045},"更新","用最小成本持续关注 OpenClaw 的官方更新，而不是等有问题时才回头补信息。",{},"/docs/release-tracking",{"title":939,"description":1075},"docs/release-tracking","PL7ZpJgBUVLVwuyy62AzMphY16PUdqxdYFYAV8Z2-Dk",{"id":1082,"title":121,"body":1083,"category":1218,"description":1219,"extension":138,"meta":1220,"navigation":140,"path":1221,"seo":1222,"stem":1223,"__hash__":1224},"docs/docs/safety-basics.md",{"type":8,"value":1084,"toc":1202},[1085,1087,1090,1093,1096,1110,1113,1116,1120,1123,1127,1130,1134,1137,1141,1144,1147,1151,1154,1157,1160,1163,1166,1169,1186,1188],[11,1086,121],{"id":121},[15,1088,1089],{},"对 OpenClaw 这种可运行、可接渠道、可扩展的系统来说，安全不是上线后再补的事情，而是第一轮配置就必须考虑的部分。",[19,1091,1092],{"id":1092},"为什么这里要先讲安全",[15,1094,1095],{},"因为一旦你开始做下面这些事情，风险面就会立刻扩大：",[29,1097,1098,1101,1104,1107],{},[32,1099,1100],{},"开远程访问",[32,1102,1103],{},"接外部消息渠道",[32,1105,1106],{},"暴露管理界面",[32,1108,1109],{},"给工具和插件更高权限",[15,1111,1112],{},"所以，中文站点在冷启动阶段就应该把“安全基础”放进核心内容，而不是藏在附录里。",[19,1114,1115],{"id":1115},"最基础的四个原则",[68,1117,1119],{"id":1118},"_1-先跑本地再谈公开入口","1. 先跑本地，再谈公开入口",[15,1121,1122],{},"第一次安装时，尽量先在本地验证最小链路，不要一开始就把入口暴露到公网。",[68,1124,1126],{"id":1125},"_2-管理入口和使用入口分开看","2. 管理入口和使用入口分开看",[15,1128,1129],{},"Control UI 这类管理入口的安全要求，通常应高于普通聊天入口。不要把它们当成同一类东西处理。",[68,1131,1133],{"id":1132},"_3-新增渠道就新增一层边界","3. 新增渠道就新增一层边界",[15,1135,1136],{},"每接一个渠道，都等于多一个入口、多一组凭证和多一层潜在错误配置。",[68,1138,1140],{"id":1139},"_4-先最小权限后逐步放开","4. 先最小权限，后逐步放开",[15,1142,1143],{},"无论是工具、hooks 还是远程能力，都应优先从最小范围开始，而不是一次性全部开放。",[19,1145,1146],{"id":1146},"中文用户最容易踩的坑",[68,1148,1150],{"id":1149},"只关注能不能跑不关注是不是暴露过头","只关注能不能跑，不关注是不是暴露过头",[15,1152,1153],{},"这会导致系统虽然“跑起来了”，但已经处在不合适的公开状态。",[68,1155,1156],{"id":1156},"在不了解边界前就接多个外部入口",[15,1158,1159],{},"这样一旦出错，排查复杂度会迅速升高。",[68,1161,1162],{"id":1162},"把安全理解成后期运维问题",[15,1164,1165],{},"实际上，它从第一次安装就开始了。",[19,1167,1168],{"id":1168},"冷启动阶段的最低建议",[29,1170,1171,1174,1177,1180,1183],{},[32,1172,1173],{},"先本地验证",[32,1175,1176],{},"先一个入口",[32,1178,1179],{},"先最小权限",[32,1181,1182],{},"先明确谁能访问管理界面",[32,1184,1185],{},"再决定是否开放远程访问",[19,1187,100],{"id":100},[29,1189,1190,1194,1198],{},[32,1191,1192],{},[106,1193,6],{"href":438},[32,1195,1196],{},[106,1197,115],{"href":114},[32,1199,1200],{},[106,1201,147],{"href":766},{"title":123,"searchDepth":124,"depth":124,"links":1203},[1204,1205,1211,1216,1217],{"id":1092,"depth":124,"text":1092},{"id":1115,"depth":124,"text":1115,"children":1206},[1207,1208,1209,1210],{"id":1118,"depth":131,"text":1119},{"id":1125,"depth":131,"text":1126},{"id":1132,"depth":131,"text":1133},{"id":1139,"depth":131,"text":1140},{"id":1146,"depth":124,"text":1146,"children":1212},[1213,1214,1215],{"id":1149,"depth":131,"text":1150},{"id":1156,"depth":131,"text":1156},{"id":1162,"depth":131,"text":1162},{"id":1168,"depth":124,"text":1168},{"id":100,"depth":124,"text":100},"运维","在开始公开接入渠道、Control UI 或远程访问前，先理解 OpenClaw 最基础的安全边界。",{},"/docs/safety-basics",{"title":121,"description":1219},"docs/safety-basics","CWtZAm9BucrxA4ACCXE9GKOhw2FRo8H5FDKIzGDvkVc",{"id":1226,"title":429,"body":1227,"category":1283,"description":1284,"extension":138,"meta":1285,"navigation":140,"path":1286,"seo":1287,"stem":1288,"__hash__":1289},"docs/docs/installation.md",{"type":8,"value":1228,"toc":1278},[1229,1231,1234,1237,1251,1253,1264,1267],[11,1230,429],{"id":429},[15,1232,1233],{},"这一页不负责覆盖所有细节，而是先给中文用户一个清晰的准备顺序。",[19,1235,1236],{"id":1236},"你需要先确认的内容",[29,1238,1239,1242,1245,1248],{},[32,1240,1241],{},"当前使用的操作系统",[32,1243,1244],{},"Node.js 版本与包管理器",[32,1246,1247],{},"是否需要访问 OpenClaw 官方仓库与相关依赖源",[32,1249,1250],{},"本地是否具备运行示例和调试环境",[19,1252,261],{"id":261},[208,1254,1255,1258,1261],{},[32,1256,1257],{},"先阅读快速入门，理解 OpenClaw 是什么",[32,1259,1260],{},"再整理本地运行环境",[32,1262,1263],{},"最后进入更具体的使用教程和最佳实践",[19,1265,1266],{"id":1266},"后续会补充",[29,1268,1269,1272,1275],{},[32,1270,1271],{},"Windows / macOS / Linux 的安装差异",[32,1273,1274],{},"常见报错与排查",[32,1276,1277],{},"针对中国网络环境的说明",{"title":123,"searchDepth":124,"depth":124,"links":1279},[1280,1281,1282],{"id":1236,"depth":124,"text":1236},{"id":261,"depth":124,"text":261},{"id":1266,"depth":124,"text":1266},"安装","面向中文用户整理 OpenClaw 的基础安装准备和环境认知。",{},"/docs/installation",{"title":429,"description":1284},"docs/installation","4-8jg8RC5u6NbYUGJVpuqdI_RWu_bxdOTfyG73REgYE",{"id":1291,"title":1292,"body":1293,"category":136,"description":1380,"extension":138,"meta":1381,"navigation":140,"path":1382,"seo":1383,"stem":1384,"__hash__":1385},"docs/docs/getting-started.md","快速入门",{"type":8,"value":1294,"toc":1376},[1295,1297,1300,1314,1317,1348,1351,1372],[11,1296,1292],{"id":1292},[15,1298,1299],{},"OpenClawCN 当前完成的是第 1 步 MVP，目标是先帮助中文用户理解 OpenClaw：",[29,1301,1302,1305,1308,1311],{},[32,1303,1304],{},"首页可以说明 OpenClawCN 的定位",[32,1306,1307],{},"文档中心已经建立目录入口",[32,1309,1310],{},"新闻列表可以承接项目动态",[32,1312,1313],{},"社区与 GitHub 入口已经放到站点导航中",[19,1315,1316],{"id":1316},"本地启动",[1318,1319,1323],"pre",{"className":1320,"code":1321,"language":1322,"meta":123,"style":123},"language-bash shiki shiki-themes github-light github-dark","npm install\nnpm run dev\n","bash",[1008,1324,1325,1338],{"__ignoreMap":123},[1326,1327,1330,1334],"span",{"class":1328,"line":1329},"line",1,[1326,1331,1333],{"class":1332},"sScJk","npm",[1326,1335,1337],{"class":1336},"sZZnC"," install\n",[1326,1339,1340,1342,1345],{"class":1328,"line":124},[1326,1341,1333],{"class":1332},[1326,1343,1344],{"class":1336}," run",[1326,1346,1347],{"class":1336}," dev\n",[19,1349,1350],{"id":1350},"当前可验证内容",[208,1352,1353,1356,1361,1366],{},[32,1354,1355],{},"打开首页，确认 Hero、功能卡片和主要入口可见",[32,1357,435,1358,1360],{},[1008,1359,1020],{},"，确认文档目录可访问",[32,1362,435,1363,1365],{},[1008,1364,1010],{},"，确认新闻列表可访问",[32,1367,435,1368,1371],{},[1008,1369,1370],{},"/api/health","，确认基础函数可返回 JSON",[1373,1374,1375],"style",{},"html pre.shiki code .sScJk, html code.shiki .sScJk{--shiki-default:#6F42C1;--shiki-dark:#B392F0}html pre.shiki code .sZZnC, html code.shiki .sZZnC{--shiki-default:#032F62;--shiki-dark:#9ECBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":123,"searchDepth":124,"depth":124,"links":1377},[1378,1379],{"id":1316,"depth":124,"text":1316},{"id":1350,"depth":124,"text":1350},"用最短时间了解 OpenClaw 是什么、适合谁，以及 OpenClawCN 当前提供了哪些中文入口。",{},"/docs/getting-started",{"title":1292,"description":1380},"docs/getting-started","nQB9yFR4cwGtGb0ZjT0zXDIhTfYDKoKqEUyklla8q94",{"id":1387,"title":1388,"body":1389,"category":1446,"description":1447,"extension":138,"meta":1448,"navigation":140,"path":1449,"seo":1450,"stem":1451,"__hash__":1452},"docs/docs/architecture.md","架构约束",{"type":8,"value":1390,"toc":1441},[1391,1393,1396,1399,1410,1413,1424,1427],[11,1392,1388],{"id":1388},[15,1394,1395],{},"为了让项目从一开始就清晰可维护，本项目默认遵循以下约束：",[19,1397,1398],{"id":1398},"内容优先",[29,1400,1401,1404,1407],{},[32,1402,1403],{},"首页优先回答“OpenClaw 是什么”",[32,1405,1406],{},"文档优先回答“如何理解和开始使用”",[32,1408,1409],{},"新闻优先承接项目更新与社区动态",[19,1411,1412],{"id":1412},"中文用户优先",[29,1414,1415,1418,1421],{},[32,1416,1417],{},"术语尽量用中文解释",[32,1419,1420],{},"安装与使用路径按中文用户习惯组织",[32,1422,1423],{},"社区、反馈和 GitHub 入口保持清晰可见",[19,1425,1426],{"id":1426},"技术边界清晰",[29,1428,1429,1432,1435,1438],{},[32,1430,1431],{},"首页、新闻和文档优先由内容驱动",[32,1433,1434],{},"第 1 步不急于接入复杂后台",[32,1436,1437],{},"第 2 步再扩展搜索、反馈和动态接口",[32,1439,1440],{},"部署平台属于内部实现，不作为对外内容主题",{"title":123,"searchDepth":124,"depth":124,"links":1442},[1443,1444,1445],{"id":1398,"depth":124,"text":1398},{"id":1412,"depth":124,"text":1412},{"id":1426,"depth":124,"text":1426},"架构","第 1 步不是功能堆砌，而是先把中文官网的内容结构和技术边界定下来。",{},"/docs/architecture",{"title":1388,"description":1447},"docs/architecture","Nu3fTEMfUFJR4nN41kyUR1vmzD8ABACHIuZy6A_i7ko",{"id":1454,"title":115,"body":1455,"category":289,"description":1574,"extension":138,"meta":1575,"navigation":140,"path":1576,"seo":1577,"stem":1578,"__hash__":1579},"docs/docs/channels-overview.md",{"type":8,"value":1456,"toc":1562},[1457,1459,1462,1465,1468,1471,1482,1485,1488,1499,1502,1506,1509,1513,1516,1520,1523,1526,1540,1543,1546,1548],[11,1458,115],{"id":115},[15,1460,1461],{},"OpenClaw 官方文档把 Channels 单独作为一个大类，这本身就说明：多渠道能力不是附属功能，而是系统结构的核心部分。",[19,1463,1464],{"id":1464},"为什么渠道能力重要",[15,1466,1467],{},"普通聊天产品通常只有一个主入口，而 OpenClaw 更强调把同一个助手体系接到不同入口上。",[15,1469,1470],{},"这带来的变化是：",[29,1472,1473,1476,1479],{},[32,1474,1475],{},"你不需要在每个平台重新建立一套助手",[32,1477,1478],{},"不同入口可以共享更一致的能力结构",[32,1480,1481],{},"后续扩展工具、模型和规则时，不必每次都从零开始",[19,1483,1484],{"id":1484},"更适合怎么理解渠道",[15,1486,1487],{},"不要一开始就把 Channels 理解成“支持了多少个平台”，更好的理解方式是：",[29,1489,1490,1493,1496],{},[32,1491,1492],{},"它是消息入口层",[32,1494,1495],{},"它连接的是同一个助手系统",[32,1497,1498],{},"它的价值在于统一，而不只是数量",[19,1500,1501],{"id":1501},"中文用户做选择时该看什么",[68,1503,1505],{"id":1504},"_1-先看自己主要在哪里使用","1. 先看自己主要在哪里使用",[15,1507,1508],{},"如果你主要通过某类消息工具工作，就优先看那个渠道，不要同时展开多个入口。",[68,1510,1512],{"id":1511},"_2-再看维护成本","2. 再看维护成本",[15,1514,1515],{},"多渠道不是越多越好。对冷启动阶段来说，先跑通一条渠道，通常比同时接三条更稳。",[68,1517,1519],{"id":1518},"_3-最后看安全和边界","3. 最后看安全和边界",[15,1521,1522],{},"每多一个渠道，就多一层入口和风险面。所以渠道扩展应当放在已经理解基础结构之后再做。",[19,1524,1525],{"id":1525},"推荐的冷启动顺序",[208,1527,1528,1531,1534,1537],{},[32,1529,1530],{},"一个管理入口",[32,1532,1533],{},"一个最常用的消息入口",[32,1535,1536],{},"跑通最小链路",[32,1538,1539],{},"再决定是否扩展第二个渠道",[19,1541,1542],{"id":1542},"这篇的边界",[15,1544,1545],{},"这一页先解决“为什么渠道能力重要”。具体某个平台怎么接、怎么配，适合单独拆成专题文档，不适合都堆在一页里。",[19,1547,100],{"id":100},[29,1549,1550,1554,1558],{},[32,1551,1552],{},[106,1553,269],{"href":268},[32,1555,1556],{},[106,1557,147],{"href":766},[32,1559,1560],{},[106,1561,121],{"href":120},{"title":123,"searchDepth":124,"depth":124,"links":1563},[1564,1565,1566,1571,1572,1573],{"id":1464,"depth":124,"text":1464},{"id":1484,"depth":124,"text":1484},{"id":1501,"depth":124,"text":1501,"children":1567},[1568,1569,1570],{"id":1504,"depth":131,"text":1505},{"id":1511,"depth":131,"text":1512},{"id":1518,"depth":131,"text":1519},{"id":1525,"depth":124,"text":1525},{"id":1542,"depth":124,"text":1542},{"id":100,"depth":124,"text":100},"先从“为什么需要多渠道”理解 OpenClaw，而不是一开始就纠结每个平台的接入细节。",{},"/docs/channels-overview",{"title":115,"description":1574},"docs/channels-overview","Dox5vweBGiKsGM91EiZthuAnYLZ5QxZNBNzaack9N6U",{"id":1581,"title":1582,"body":1583,"category":1620,"description":1621,"extension":138,"meta":1622,"navigation":140,"path":1623,"seo":1624,"stem":1625,"__hash__":1626},"docs/docs/community.md","社区支持",{"type":8,"value":1584,"toc":1616},[1585,1587,1590,1593,1603,1605],[11,1586,1582],{"id":1582},[15,1588,1589],{},"OpenClawCN 不只是静态介绍页，还会逐步承担中文社区入口的作用。",[19,1591,1592],{"id":1592},"当前入口",[29,1594,1595,1597,1600],{},[32,1596,961],{},[32,1598,1599],{},"Issue / 问题反馈",[32,1601,1602],{},"后续贡献说明",[19,1604,1266],{"id":1266},[29,1606,1607,1610,1613],{},[32,1608,1609],{},"常见问题整理",[32,1611,1612],{},"贡献指南",[32,1614,1615],{},"中文社区沟通渠道",{"title":123,"searchDepth":124,"depth":124,"links":1617},[1618,1619],{"id":1592,"depth":124,"text":1592},{"id":1266,"depth":124,"text":1266},"社区","汇总 GitHub、问题反馈、贡献方式和后续社区入口。",{},"/docs/community",{"title":1582,"description":1621},"docs/community","AISY-jwqalqwbAXF7IcaWZXmjGSWBBHhT60T6WJK7BY",1773044725104]